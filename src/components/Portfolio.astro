---
import { Github, Linkedin, MessageSquare, Send } from '@lucide/astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import Loader from './Loader.astro';
import { projects } from '../data/projects';

const links = [
  { href: 'https://github.com/LordSA', icon: Github, label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/shibili-aman-tk', icon: Linkedin, label: 'LinkedIn' },
  { href: 'https://wa.me/919037619447', icon: MessageSquare, label: 'WhatsApp' },
  { href: 'https://t.me/shibili_offline', icon: Send, label: 'Telegram' },
];

const techStack = [
  { name: 'C++', icon: 'cplusplus', level: 2 },
  { name: 'Python', icon: 'python', level: 3 },
  { name: 'JavaScript', icon: 'javascript', level: 2 },
  { name: 'Java', icon: 'java', level: 2 },
  { name: 'Flutter', icon: 'flutter', level: 1 },
  { name: 'Figma', icon: 'figma', level: 3 },
];

const skillLogicTags: Record<string, string> = {
  'C++': 'c++ cpp systems performance game engine optimization',
  Python: 'python automation backend scripting bot data ai',
  JavaScript: 'javascript web frontend ui nextjs react astro fullstack',
  Java: 'java game backend oop',
  Flutter: 'flutter mobile ui app cross-platform',
  Figma: 'figma design ui ux prototyping interface',
};

const inferProjectLogicTags = (project: (typeof projects)[number]) => {
  const base = [project.title, project.category, project.description].join(' ').toLowerCase();
  const inferred: string[] = [];

  if (/python|automation|bot|declutter/.test(base)) inferred.push('python automation backend bot scripting');
  if (/web|typescript|next|frontend|ui|ux|e-commerce|funding|management/.test(base)) inferred.push('javascript web frontend ui fullstack');
  if (/java|game/.test(base)) inferred.push('java game');
  if (/unity|game/.test(base)) inferred.push('cpp game engine performance');
  if (/security|secure|medical|database/.test(base)) inferred.push('backend security data architecture');

  return `${base} ${inferred.join(' ')}`;
};
---

<Loader />

<main class="overflow-x-hidden pt-12 md:pt-16">
  <Navbar />
  
  <section class="min-h-screen flex flex-col lg:flex-row justify-center items-center px-6 sm:px-10 md:px-24 pt-10 md:pt-20 lg:pt-24 text-left bg-transparent sticky top-0 -z-0 overflow-hidden font-mono">
    
    <div class="max-w-4xl flex flex-col items-start py-2 z-10 w-full order-2 lg:order-1 relative">
      <div class="mb-4 md:mb-8 inline-block px-4 py-1.5 border border-[#c5a059]/40 bg-[#08080a] text-[#c5a059] text-[9px] uppercase tracking-[0.2em] font-bold shadow-[2px_2px_0px_#c5a059] gsap-hero-stagger opacity-0 translate-y-4">
        B.Tech CSE Student • Full-Stack Explorer
      </div>
      <h2 class="text-xs md:text-sm font-bold tracking-[0.3em] text-[#8a857a] mb-2 md:mb-4 uppercase gsap-hero-stagger opacity-0 translate-y-4">SHIBILI AMAN TK</h2>
      <h1 class="text-4xl xs:text-5xl sm:text-6xl md:text-[5.5rem] font-extrabold tracking-tighter leading-[0.95] mb-6 md:mb-10 uppercase font-display select-none gsap-hero-title opacity-0 translate-y-8">
        Coding & <br/> <span class="text-[#c5a059] hover:text-white transition-colors duration-500">Building</span>
      </h1>
      <p class="text-sm md:text-xl text-[#8a857a] max-w-xl mb-8 md:mb-12 leading-relaxed font-sans gsap-hero-stagger opacity-0 translate-y-4">
        A <span class="text-white font-semibold">Full-Stack Developer</span> and UI/UX enthusiast crafting robust applications, modular web systems, and high-performance interactive interfaces.
      </p>
      
      <div class="flex lg:hidden justify-center items-center relative transition-all duration-1000 mt-4 mb-4 xs:mb-6 w-full">
        <div class="relative group w-full flex justify-center">
          <div class="border-2 border-[#c5a059] shadow-[8px_8px_0px_#c5a059] bg-[#08080a] p-2">
            <img 
              src="/shibili.webp" 
              alt="Shibili Aman TK" 
              class="relative z-10 w-[240px] aspect-[4/5] object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
            />
          </div>
          <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 border border-[#c5a059] bg-[#08080a] p-3 shadow-[4px_4px_0px_#c5a059] z-20">
            <p class="text-[7px] uppercase tracking-[0.4em] text-[#8a857a] mb-1">Status</p>
            <p class="text-[8px] font-bold tracking-widest uppercase text-white flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#00E676] animate-pulse"></span>
              GHOST MODE
            </p>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row justify-start items-center gap-4 md:gap-6 z-20 w-full lg:w-auto mt-12 xs:mt-4 gsap-hero-stagger opacity-0 translate-y-4">
        <a href="https://wa.me/919037619447" target="_blank" class="btn-brutalist text-center w-full sm:w-48">
          Let's Develop
        </a>
        <div class="flex gap-4 w-full sm:w-auto justify-center">
          {links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="p-4 bg-[#08080a] border border-[#c5a059] hover:bg-[#c5a059] hover:text-[#08080a] transition-all duration-200 shadow-[3px_3px_0px_#c5a059] hover:translate-x-[-1px] hover:translate-y-[-1px]" aria-label={link.label}>
              <link.icon size={18} class="text-[#c5a059] hover:text-inherit transition-colors" />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="hidden lg:flex flex-1 justify-end items-center relative h-full transition-all duration-1000 mt-20 lg:mt-5 w-full order-1 lg:order-2">
      <div class="relative group w-full flex justify-end">
        <div class="border-2 border-[#c5a059] shadow-[12px_12px_0px_#c5a059] bg-[#08080a] p-3">
          <img 
            src="/shibili.webp" 
            alt="Shibili Aman TK" 
            class="relative z-10 lg:w-[360px] aspect-[4/5] object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
          />
        </div>
        <div class="absolute -bottom-6 lg:left-[-2rem] lg:translate-x-0 border-2 border-[#c5a059] bg-[#08080a] p-4 shadow-[4px_4px_0px_#c5a059] z-20">
          <p class="text-[8px] uppercase tracking-[0.4em] text-[#8a857a] mb-1">Status</p>
          <p class="text-[10px] font-bold tracking-widest uppercase text-white flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[#00E676] animate-pulse"></span>
            GHOST MODE
          </p>
        </div>
      </div>
    </div>
    
  </section>

  <section id="about" class="py-20 md:py-32 px-6 sm:px-10 md:px-24 bg-transparent z-10 relative">
    <div class="grid lg:grid-cols-12 gap-12 md:gap-20">
      <div class="lg:col-span-1 border-r border-[#c5a059]/20 hidden lg:block">
        <div class="sticky top-40 text-[9px] font-bold uppercase tracking-[0.4em] text-[#c5a059] [writing-mode:vertical-lr] rotate-180">
          Identity / Profile
        </div>
      </div>
      
      <div class="lg:col-span-6">
        <h2 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#c5a059] mb-8 scramble-text" data-text="System Log: About Me">System Log: About Me</h2>
        <div class="space-y-6 md:space-y-8 text-lg md:text-2xl font-light leading-relaxed">
          <p class="text-white font-display">
            I am a <span class="text-[#c5a059] font-semibold underline decoration-2 decoration-[#c5a059] underline-offset-8">Computer Science Student</span> with a deep fascination for the intersection of logical backend frameworks and elegant interactive designs.
          </p>
          <p class="text-[#8a857a]">
            Specialized in system architecture, automation tooling, and building practical applications. Bridging high-performance code blocks with clean luxury aesthetics.
          </p>
          <div class="flex flex-wrap gap-2 pt-4">
            <span class="px-3 py-1.5 border border-[#c5a059]/30 bg-[#08080a] text-[9px] uppercase tracking-widest text-[#c5a059]">B.Tech CSE</span>
            <span class="px-3 py-1.5 border border-[#c5a059]/30 bg-[#08080a] text-[9px] uppercase tracking-widest text-[#c5a059]">Automation Architect</span>
            <span class="px-3 py-1.5 border border-[#c5a059]/30 bg-[#08080a] text-[9px] uppercase tracking-widest text-[#c5a059]">UI/UX Explorer</span>
          </div>
        </div>
      </div>
      
      <div class="lg:col-span-5 flex flex-col justify-start">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#c5a059] mb-8">Tech Arsenal</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-2 gap-4">
           {techStack.map((tech) => (
            <div class="bg-[#08080a] border border-[#c5a059]/30 flex flex-col justify-between p-4 group hover:border-[#c5a059] hover:shadow-[4px_4px_0px_#c5a059] transition-all duration-300 gsap-tech-item opacity-0 translate-y-8" data-logic-skill={skillLogicTags[tech.name] ?? tech.name.toLowerCase()}>
                <div class="flex justify-between items-start mb-4">
                  <img 
                    src={tech.icon === 'figma' ? 'https://devicon-website.vercel.app/api/figma/original.svg' : `https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tech.icon}/${tech.icon}-original.svg`} 
                    alt={tech.name} 
                    class="w-8 h-8 grayscale opacity-50 group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-500"
                  />
                  <span class="text-[8px] font-mono uppercase tracking-widest text-[#8a857a] group-hover:text-white transition-colors">{tech.name}</span>
                </div>
                <div>
                  <div class="flex gap-1">
                    {[1, 2, 3].map((dot) => (
                      <div class={`w-2.5 h-1.5 transition-all duration-500 ${dot <= tech.level ? 'bg-[#c5a059]' : 'bg-[#c5a059]/10'}`}></div>
                    ))}
                  </div>
                </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="projects" class="py-20 md:py-32 px-4 xs:px-6 sm:px-10 md:px-24 bg-transparent z-10 relative">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
        <div>
          <h2 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#c5a059] mb-4 scramble-text" data-text="Selected Works">Selected Works</h2>
          <h3 class="text-3xl xs:text-5xl md:text-6xl font-extrabold uppercase font-display">Featured <br/> <span class="text-[#c5a059]">Projects</span></h3>
        </div>
        <div class="hidden md:block text-[9px] uppercase tracking-[0.4em] font-mono text-[#8a857a] border border-[#c5a059]/30 px-3 py-1.5">
          QUALITY // SCALE // ACCURACY
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {projects.slice(0, 4).map((project, index) => (
          <a href={`/project/${project.slug}`} class="group cursor-pointer block border-2 border-[#c5a059] p-4 bg-[#08080a] shadow-[6px_6px_0px_#c5a059] hover:shadow-[10px_10px_0px_#c5a059] transition-all duration-300 hover:translate-x-[-2px] hover:translate-y-[-2px] gsap-project-card opacity-0 translate-y-12" data-logic-project={inferProjectLogicTags(project)}>
            <div class="aspect-[16/10] bg-[#08080a] overflow-hidden mb-6 border border-[#c5a059]/20 relative">
              <img src={project.image || "https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&fit=crop&q=80&w=1000"} alt={project.title} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 grayscale group-hover:grayscale-0" />
              <div class="absolute top-4 left-4 bg-[#08080a] border border-[#c5a059] text-[#c5a059] font-mono text-xs px-2.5 py-1 font-bold">
                0{index + 1}
              </div>
              <div class="absolute inset-0 bg-[#08080a]/80 flex items-center justify-center p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                 <span class="text-[10px] font-mono uppercase tracking-widest font-bold border-b-2 border-[#c5a059] pb-1 text-[#c5a059]">View Project Details</span>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row justify-between items-start px-1 gap-4">
              <div>
                <h4 class="text-xl md:text-2xl font-bold uppercase font-display tracking-tight text-white mb-2 group-hover:text-[#c5a059] transition-colors">{project.title}</h4>
                <p class="text-[#8a857a] text-xs md:text-sm font-sans line-clamp-2 leading-relaxed">{project.description}</p>
              </div>
              <span class="text-[9px] font-mono uppercase tracking-widest text-[#c5a059] bg-[#c5a059]/10 border border-[#c5a059]/20 px-3 py-1 rounded-none whitespace-nowrap">{project.category}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a href="/projects" class="btn-brutalist">
          Explore All Works
        </a>
      </div>
    </div>
  </section>

  <section id="contact" class="py-20 md:py-32 px-4 xs:px-6 sm:px-10 md:px-24 relative bg-transparent z-10">
    <div class="max-w-5xl mx-auto text-center">
       <div class="inline-block mb-8">
          <div class="w-3 h-3 bg-[#00E676] rounded-full animate-pulse shadow-[0_0_8px_#00E676]"></div>
       </div>
       <h2 class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#c5a059] mb-6 scramble-text" data-text="Incoming Transmission">Incoming Transmission</h2>
       <p class="text-3xl xs:text-5xl md:text-7xl font-extrabold tracking-tighter uppercase font-display mb-12 text-white">
         Let's Build the <span class="text-[#c5a059]">Future</span> Together.
       </p>
       
       <div class="flex flex-col sm:flex-row justify-center gap-4 md:gap-8 mb-20 max-w-md mx-auto">
         <a href="/contact" class="btn-brutalist w-full text-center">
           Initiate Contact
         </a>
         <a href="https://wa.me/919037619447" target="_blank" class="btn-brutalist-white w-full text-center">
           WhatsApp Direct
         </a>
       </div>

       <div class="pt-12 border-t border-[#c5a059]/20 mt-16">
          <h4 class="text-[9px] font-mono uppercase tracking-[0.4em] text-[#8a857a] mb-8">Development Analytics</h4>
          <div class="mt-8 flex justify-center">
             <img src="https://github-profile-summary-cards.vercel.app/api/cards/profile-details?username=LordSA&theme=radical" alt="GitHub Participation" class="w-full max-w-4xl grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all border-2 border-[#c5a059]/30 p-2 bg-[#08080a] hidden md:block" />
          </div>
       </div>
    </div>
  </section>
</main>

<Footer />

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    setTimeout(() => {
      gsap.to('.gsap-hero-title', {
        opacity: 1,
        y: 0,
        duration: 1.2,
        ease: 'power3.out',
      });

      gsap.to('.gsap-hero-stagger', {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        stagger: 0.1,
        delay: 0.2
      });
    }, 1500);

    gsap.to('.gsap-tech-item', {
      scrollTrigger: {
        trigger: '#about',
        start: 'top 70%',
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.05,
      ease: 'power3.out'
    });

    gsap.to('.gsap-project-card', {
      scrollTrigger: {
        trigger: '#projects',
        start: 'top 60%',
      },
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: 'power3.out'
    });

    const chars = '!<>-_\\/[]{}—=+*^?#________';
    gsap.utils.toArray('.scramble-text').forEach((el: any) => {
      ScrollTrigger.create({
        trigger: el,
        start: 'top 85%',
        onEnter: () => {
          const originalText = el.dataset.text;
          let iteration = 0;
          gsap.to({}, {
            duration: 1.5,
            onUpdate: () => {
              iteration += 1;
              el.innerText = originalText.split('').map((_: string, index: number) => {
                if (index < iteration / 2) return originalText[index];
                return chars[Math.floor(Math.random() * chars.length)];
              }).join('');
            }
          });
        },
        once: true
      });
    });
  };

  document.addEventListener('astro:page-load', initAnimations);
</script>