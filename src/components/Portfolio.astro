---
import { Github, Linkedin, ExternalLink, Mail, MessageSquare, Twitter } from '@lucide/astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import Loader from './Loader.astro';
import CustomCursor from './CustomCursor.astro';
import { projects } from '../data/projects';

const links = [
  { href: 'https://github.com/LordSA', icon: Github, label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/shibili-aman-tk', icon: Linkedin, label: 'LinkedIn' },
  { href: 'https://tinkerhub.org/@shibiliamantk', icon: ExternalLink, label: 'TinkerHub' },
  { href: 'https://x.com/shibiliii_aman', icon: Twitter, label: 'Twitter' },
];

const techStack = [
  { name: 'C++', icon: 'cplusplus', level: 2 },
  { name: 'Python', icon: 'python', level: 3 },
  { name: 'JavaScript', icon: 'javascript', level: 2 },
  { name: 'Java', icon: 'java', level: 2 },
  { name: 'Flutter', icon: 'flutter', level: 1 },
  { name: 'Figma', icon: 'figma', level: 3 },
];

const skillLogicTags: Record<string, string> = {
  'C++': 'c++ cpp systems performance game engine optimization',
  Python: 'python automation backend scripting bot data ai',
  JavaScript: 'javascript web frontend ui nextjs react astro fullstack',
  Java: 'java game backend oop',
  Flutter: 'flutter mobile ui app cross-platform',
  Figma: 'figma design ui ux prototyping interface',
};

const inferProjectLogicTags = (project: (typeof projects)[number]) => {
  const base = [project.title, project.category, project.description].join(' ').toLowerCase();
  const inferred: string[] = [];

  if (/python|automation|bot|declutter/.test(base)) inferred.push('python automation backend bot scripting');
  if (/web|typescript|next|frontend|ui|ux|e-commerce|funding|management/.test(base)) inferred.push('javascript web frontend ui fullstack');
  if (/java|game/.test(base)) inferred.push('java game');
  if (/unity|game/.test(base)) inferred.push('cpp game engine performance');
  if (/security|secure|medical|database/.test(base)) inferred.push('backend security data architecture');

  return `${base} ${inferred.join(' ')}`;
};
