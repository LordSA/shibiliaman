---
import { Github, Linkedin, ExternalLink, Mail, MessageSquare, Twitter } from '@lucide/astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import Loader from './Loader.astro';
import CustomCursor from './CustomCursor.astro';
import { projects } from '../data/projects';

const links = [
  { href: 'https://github.com/LordSA', icon: Github, label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/shibili-aman-tk', icon: Linkedin, label: 'LinkedIn' },
  { href: 'https://tinkerhub.org/@shibiliamantk', icon: ExternalLink, label: 'TinkerHub' },
  { href: 'https://x.com/shibiliii_aman', icon: Twitter, label: 'Twitter' },
];

const techStack = [
  { name: 'C++', icon: 'cplusplus', level: 2 },
  { name: 'Python', icon: 'python', level: 3 },
  { name: 'JavaScript', icon: 'javascript', level: 2 },
  { name: 'Java', icon: 'java', level: 2 },
  { name: 'Flutter', icon: 'flutter', level: 1 },
  { name: 'Figma', icon: 'figma', level: 3 },
];
---

<Loader />

<main class="overflow-x-hidden">
  <Navbar />
  <section class="min-h-screen flex flex-col lg:flex-row justify-center items-center px-6 sm:px-10 md:px-24 pt-10 md:pt-20 lg:pt-24 text-left bg-[radial-gradient(circle_at_20%_50%,_rgba(255,255,255,0.03)_0%,_transparent_50%)] sticky top-0 bg-black -z-0 overflow-hidden font-mono">
    
    <div class="max-w-4xl animate-fade-in flex flex-col items-start py-2 z-10 w-full order-2 lg:order-1">
       <div class="mb-4 md:mb-8 inline-block px-3 md:px-4 py-1 md:py-1.5 border border-white/10 rounded-full text-[8px] md:text-[10px] uppercase tracking-[0.2em] md:tracking-[0.3em] bg-white/5 backdrop-blur-md shadow-2xl">
        B.Tech CSE Student • Full-Stack Explorer
      </div>
      <h2 class="text-base md:text-2xl font-light tracking-[0.3em] md:tracking-[0.4em] text-zinc-500 mb-2 md:mb-4 uppercase">SHIBILI AMAN TK</h2>
      <h1 class="text-5xl xs:text-6xl sm:text-6xl md:text-[7rem] font-bold tracking-tighter leading-[0.9] mb-6 md:mb-10 uppercase cursor-default select-none transition-all duration-700 hover:tracking-tight">
        Coding and <br/> <span class="text-zinc-800 hover:text-white transition-all duration-1000">Building</span>
      </h1>
      <p class="text-xs xs:text-sm md:text-2xl text-zinc-400 max-w-2xl mb-8 md:mb-14 leading-relaxed font-light text-balance font-sans">
        A<span class="text-white font-medium"> Full-Stack Developer</span> and UI/UX Enthusiast passionate about building scalable solutions and crafting elegant user experiences.
      </p>
      
      <div class="flex lg:hidden justify-center items-center relative transition-all duration-1000 mt-4 mb-4 xs:mb-6 w-full">
          <div class="relative group w-full flex justify-center">
              <div class="absolute inset-x-0 -inset-y-10 bg-gradient-to-b from-white/5 to-transparent blur-3xl rounded-full scale-150 group-hover:from-white/10 transition-all duration-1000"></div>
              <img 
                  src="/shibili.webp" 
                  alt="Shibili Aman TK" 
                  class="relative z-10 w-[260px] xs:w-[300px] aspect-[4/5] object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-1000 rounded-[2rem] border border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.5)]"
              />
              <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 border border-white/10 bg-black/80 backdrop-blur-xl p-4 rounded-xl z-20 animate-float">
                  <p class="text-[7px] uppercase tracking-[0.4em] text-zinc-600 mb-1">Status</p>
                  <p class="text-[9px] font-bold tracking-widest uppercase text-white">LIVES IN GHOST MODE</p>
              </div>
          </div>
      </div>

      <div class="flex flex-col lg:flex-row justify-start items-center gap-4 md:gap-6 z-20 w-full lg:w-auto mt-12 xs:mt-4">
        <a href="https://instagram.com/__shibiliii._" class="group relative w-full lg:w-48 text-center px-8 lg:px-6 py-5 bg-white text-black rounded-full text-[11px] md:text-xs uppercase tracking-[0.2em] transition-all font-bold shadow-[0_0_40px_rgba(255,255,255,0.1)] active:scale-95 overflow-hidden cursor-pointer whitespace-nowrap">
          <span class="relative z-10 transition-colors duration-500 group-hover:text-white">
            Let's Develop
          </span>
          <div class="absolute inset-0 bg-green-900 translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-500 ease-out"></div>
        </a>
        <div class="flex gap-4 w-full lg:w-auto justify-center">
          {links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="p-4 md:p-5 bg-zinc-950 border border-white/5 rounded-full hover:bg-white hover:text-black transition-all group backdrop-blur-sm relative cursor-pointer" aria-label={link.label}>
              <link.icon size={20} class="text-zinc-500 group-hover:text-inherit transition-all transform group-hover:scale-110 md:w-[22px] md:h-[22px]" />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="hidden lg:flex flex-1 justify-end items-center relative h-full transition-all duration-1000 mt-20 lg:mt-5 w-full order-1 lg:order-2">
        <div class="relative group w-full flex justify-end">
            <div class="absolute inset-x-0 -inset-y-10 bg-gradient-to-b from-white/5 to-transparent blur-3xl rounded-full scale-150 group-hover:from-white/10 transition-all duration-1000"></div>
            <img 
                src="/shibili.webp" 
                alt="Shibili Aman TK" 
                class="relative z-10 lg:w-[420px] aspect-[4/5] object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-1000 rounded-[2rem] border border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.5)]"
            />
            <div class="absolute -bottom-6 lg:left-[-2rem] lg:translate-x-0 border border-white/10 bg-black/80 backdrop-blur-xl lg:p-6 rounded-xl lg:rounded-2xl z-20 animate-float">
                <p class="text-[7px] lg:text-[9px] uppercase tracking-[0.4em] text-zinc-600 mb-1">Status</p>
                <p class="text-[9px] lg:text-xs font-bold tracking-widest uppercase text-white">LIVES IN GHOST MODE</p>
            </div>
        </div>
    </div>
    
  </section>

  <section id="about" class="py-20 md:py-40 px-6 sm:px-10 md:px-24 border-t border-white/5 bg-black z-10 relative">
    <div class="grid lg:grid-cols-12 gap-12 md:gap-20">
      <div class="lg:col-span-1 border-r border-white/5 hidden lg:block">
        <div class="sticky top-40 text-[10px] uppercase tracking-[0.4em] text-zinc-600 [writing-mode:vertical-lr] rotate-180">
          Identity / Bio
        </div>
      </div>
      
      <div class="lg:col-span-6">
        <h2 class="text-[10px] uppercase tracking-[0.4em] text-zinc-600 mb-8 md:mb-12">System Log: About Me</h2>
        <div class="space-y-6 md:space-y-8 text-xl md:text-4xl font-light leading-snug">
          <p>
            I am a <span class="text-white font-normal underline decoration-zinc-800 underline-offset-8">Computer Science student</span> with a deep fascination for the intersection of logic and creativity.
          </p>
          <p class="text-zinc-500">
            Passionate about coding, building, and <span class="text-zinc-300">problem-solving</span>. Exploring the realms of UI/UX design to bridge the gap between functionality and aesthetics.
          </p>
          <div class="flex flex-wrap gap-2 md:gap-3 pt-4">
            <span class="px-3 md:px-4 py-1.5 md:py-2 bg-zinc-900/50 border border-white/10 rounded-lg text-[9px] md:text-[10px] uppercase tracking-widest text-zinc-400">Intermediate Code Warrior</span>
            <span class="px-3 md:px-4 py-1.5 md:py-2 bg-zinc-900/50 border border-white/10 rounded-lg text-[9px] md:text-[10px] uppercase tracking-widest text-zinc-400">Telegram Bot Architect</span>
            <span class="px-3 md:px-4 py-1.5 md:py-2 bg-zinc-900/50 border border-white/10 rounded-lg text-[9px] md:text-[10px] uppercase tracking-widest text-zinc-400">UI/UX Explorer</span>
          </div>
        </div>
      </div>
      
      <div class="lg:col-span-5 flex flex-col justify-start">
        <h3 class="text-[10px] uppercase tracking-[0.4em] text-zinc-600 mb-8 md:mb-12">Tech Arsenal</h3>
        <div class="grid grid-cols-2 xs:grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-3 md:gap-4">
           {techStack.map((tech) => (
            <div class="bg-zinc-950/50 border border-white/5 flex flex-col sm:flex-row items-center gap-3 md:gap-4 p-4 md:p-5 rounded-2xl group hover:border-white/10 hover:bg-zinc-900/50 transition-all duration-500 backdrop-blur-sm text-center sm:text-left">
                <div class="relative">
                  <img 
                      src={tech.icon === 'figma' ? 'https://devicon-website.vercel.app/api/figma/original.svg' : `https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tech.icon}/${tech.icon}-original.svg`} 
                      alt={tech.name} 
                      class="w-10 h-10 opacity-40 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700 brightness-125"
                  />
                </div>
                <div class="flex-1">
                  <span class="text-[10px] uppercase tracking-widest block mb-2 opacity-60 font-medium group-hover:opacity-100 transition-opacity">{tech.name}</span>
                  <div class="flex gap-1.5">
                    {[1, 2, 3].map((dot) => (
                      <div class={`w-2 h-2 rounded-full transition-all duration-700 ${dot <= tech.level ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)] scale-110' : 'bg-zinc-800 opacity-30 shadow-none'}`}></div>
                    ))}
                  </div>
                </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="projects" class="py-12 md:py-40 px-4 xs:px-6 sm:px-10 md:px-24 border-t border-white/5 relative overflow-hidden bg-black z-10">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-24 gap-6">
        <div>
          <h2 class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] text-zinc-600 mb-4 md:mb-8">Selected Works</h2>
          <h3 class="text-3xl xs:text-5xl md:text-7xl font-bold uppercase tracking-tighter">Featured <br/> <span class="text-zinc-800">Projects</span></h3>
        </div>
        <div class="hidden md:block text-[10px] uppercase tracking-[0.4em] text-zinc-600 italic pb-4">
          Quality / Stability / Detail
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
        {projects.slice(0, 4).map((project) => (
          <a href={`/project/${project.slug}`} class="group cursor-pointer block">
            <div class="aspect-[16/10] bg-zinc-900 rounded-2xl md:rounded-3xl overflow-hidden mb-6 md:mb-8 border border-white/5 relative">
              <img src={project.image || "https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&fit=crop&q=80&w=1000"} alt={project.title} class="w-full h-full object-cover opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-1000 md:grayscale md:hover:grayscale-0" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-6 md:p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                 <span class="text-[10px] md:text-xs uppercase tracking-widest font-bold border-b border-white pb-1">View Project Details</span>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row justify-between items-start px-2 gap-4">
              <div>
                <h4 class="text-xl md:text-2xl font-bold uppercase tracking-tight mb-2 group-hover:text-zinc-300 transition-colors">{project.title}</h4>
                <p class="text-zinc-500 text-sm md:text-base font-light max-w-sm">{project.description}</p>
              </div>
              <span class="text-[9px] md:text-[10px] uppercase tracking-widest text-zinc-600 bg-zinc-900/50 border border-white/5 px-3 py-1 rounded-full whitespace-nowrap">{project.category}</span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 md:mt-12 text-center">
        <a href="/projects" class="inline-flex items-center gap-2 px-8 py-4 md:px-10 md:py-5 bg-white text-black rounded-full text-[9px] md:text-[10px] uppercase tracking-widest font-bold hover:bg-zinc-200 transition-all transform hover:-translate-y-1">
          Explore All Works
        </a>
      </div>
    </div>
  </section>

  <section id="contact" class="py-12 md:py-40 px-4 xs:px-6 sm:px-10 md:px-24 border-t border-white/5 relative bg-black z-10">
    <div class="max-w-5xl mx-auto text-center">
       <div class="inline-block mb-8 md:mb-12 animate-pulse">
          <div class="w-3 h-3 bg-white rounded-full"></div>
       </div>
       <h2 class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] text-zinc-600 mb-6 md:mb-12">Incoming Transmission</h2>
       <p class="text-3xl xs:text-5xl md:text-9xl font-bold tracking-tight md:tracking-[ -0.05em] uppercase mb-10 md:mb-16 italic text-balance">
         Let's Build the <span class="text-zinc-800">Future</span> Together.
       </p>
       
       <div class="flex flex-col sm:flex-row justify-center gap-4 md:gap-8 mb-16 md:mb-32">
         <a href="/contact" class="px-8 md:px-12 py-4 md:py-6 bg-white text-black font-bold uppercase tracking-[0.2em] rounded-full hover:bg-zinc-200 transition-all transform hover:-translate-y-1 text-xs md:text-sm">
           Initiate Contact
         </a>
         <a href="https://linkedin.com/in/shibili-aman-tk" target="_blank" class="px-8 md:px-12 py-4 md:py-6 border border-white/20 text-white font-bold uppercase tracking-[0.2em] rounded-full hover:bg-white hover:text-black transition-all transform hover:-translate-y-1 text-xs md:text-sm bg-black/40 backdrop-blur-sm">
           LinkedIn Profile
         </a>
       </div>

       <div class="pt-12 md:pt-24 border-t border-white/5 mt-12 md:mt-20">
          <h4 class="text-[9px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] text-zinc-600 mb-8 md:mb-12">Growth Metrics / Analytics</h4>
          <div class="flex flex-col lg:flex-row gap-6 md:gap-8 justify-center items-center">
             <img src="https://github-readme-stats.vercel.app/api?username=LordSA&show_icons=true&theme=radical&hide_border=true&count_private=true" alt="Github Stats" class="h-28 md:h-40 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all rounded-xl w-full max-w-md object-contain" />
             <img src="https://github-readme-streak-stats.herokuapp.com/?user=LordSA&theme=tokyonight&hide_border=true" alt="Github Streak" class="h-28 md:h-40 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all rounded-xl w-full max-w-md object-contain" />
          </div>
       </div>
    </div>
  </section>
</main>

<Footer />

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    100% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 3s ease-in-out infinite alternate;
  }
</style>