---
import { Github, Linkedin, MessageSquare, Send } from '@lucide/astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import Loader from './Loader.astro';
import PhysicsCanvas from './PhysicsCanvas.tsx';
import { projects } from '../data/projects';

const links = [
  { href: 'https://github.com/LordSA', icon: Github, label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/shibili-aman-tk', icon: Linkedin, label: 'LinkedIn' },
  { href: 'https://wa.me/919037619447', icon: MessageSquare, label: 'WhatsApp' },
  { href: 'https://t.me/shibili_offline', icon: Send, label: 'Telegram' },
];
---

<Loader />

<main class="w-full bg-[#000000] text-white pt-20">
  <Navbar />

  <section class="grid grid-cols-1 lg:grid-cols-12 border-b-4 border-[#00ffd1] min-h-screen">
    
    <div class="lg:col-span-7 flex flex-col justify-between border-r-0 lg:border-r-4 border-[#00ffd1] p-6 sm:p-10 md:p-16">
      
      <div class="space-y-6">
        <div class="inline-block px-4 py-1.5 border-3 border-[#00ffd1] bg-[#101114] text-[#00ffd1] text-[10px] font-black uppercase tracking-widest shadow-[4px_4px_0px_#ffffff]">
          VERIFIED NODE // FULL-STACK ENGINE
        </div>
        
        <h1 class="text-4xl sm:text-6xl md:text-[5.5rem] font-extrabold uppercase tracking-tighter leading-[0.9] font-display">
          SHIBILI AMAN<br/>
          <span class="text-[#00ffd1]">BUILDING IDEAS</span>
        </h1>

        <p class="text-[#8a909a] text-sm md:text-lg max-w-xl font-sans leading-relaxed">
          B.Tech CSE student specializing in structural code architecture, scalable automation systems, and high-impact web design interfaces. Built on efficiency.
        </p>
      </div>

      <div class="mt-12 space-y-6">
        <div class="flex flex-col sm:flex-row items-stretch gap-4 max-w-md">
          <a href="https://wa.me/919037619447" target="_blank" class="btn-neo text-center flex-1">
            Let's Develop
          </a>
          <a href="/contact" class="btn-neo-white text-center flex-1">
            Nodes Setup
          </a>
        </div>

        <div class="flex gap-4 pt-4 border-t border-[#00ffd1]/20">
          {links.map((link) => (
            <a 
              href={link.href} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="p-4 bg-[#101114] border-2 border-[#00ffd1] shadow-[3px_3px_0px_#00ffd1] hover:bg-[#00ffd1] hover:text-black transition-all hover:translate-x-[-1px] hover:translate-y-[-1px] hover:shadow-[4px_4px_0px_#ffffff]" 
              aria-label={link.label}
            >
              <link.icon size={16} class="text-[#00ffd1] hover:text-inherit" />
            </a>
          ))}
        </div>
      </div>

    </div>

    <div class="lg:col-span-5 flex flex-col justify-between p-6 sm:p-10 md:p-16 relative bg-[#101114]" style="background-image: radial-gradient(#00ffd1 1px, transparent 1px); background-size: 24px 24px;">
      
      <div class="border-3 border-[#00ffd1] bg-[#000000] p-4 shadow-[4px_4px_0px_#c5a059]">
        <span class="text-[9px] uppercase tracking-widest text-[#00ffd1] font-bold block mb-1">Active Object</span>
        <div class="text-white text-xs font-bold font-display">TorusKnot // Octahedron Nest</div>
      </div>

      <div class="border-3 border-black bg-black p-4 shadow-[4px_4px_0px_#00ffd1] mt-auto">
        <span class="text-[9px] uppercase tracking-[0.4em] text-[#8a909a] mb-1 block">Status Output</span>
        <div class="text-xs font-bold text-white flex items-center gap-2">
          <span class="w-2.5 h-2.5 bg-[#00E676] animate-pulse"></span>
          SYS: EXTREME_BRUTAL_MODE
        </div>
      </div>

    </div>

  </section>

  <section id="about" class="grid grid-cols-1 lg:grid-cols-12 border-b-4 border-[#00ffd1]">
    
    <div class="lg:col-span-6 border-r-0 lg:border-r-4 border-[#00ffd1] p-6 sm:p-10 md:p-16 flex flex-col justify-between gap-12">
      <div>
        <h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-[#00ffd1] mb-6 scramble-text" data-text="SYSTEM_BIO // LOGGER">SYSTEM_BIO // LOGGER</h2>
        <div class="space-y-6 text-lg md:text-xl font-light leading-relaxed font-sans text-white/90">
          <p>
            Operating at the threshold of logic and design. I build clean, high-performance systems and structure databases for production scaling.
          </p>
          <blockquote class="border-l-4 border-[#00ffd1] pl-4 italic text-[#8a909a] text-sm md:text-base">
            "Brutalism is not about roughness. It is about exposing the structure, details, and raw functionality of the build."
          </blockquote>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 pt-4">
        <span class="px-3 py-1.5 border border-[#00ffd1]/30 bg-[#101114] text-[9px] uppercase tracking-widest text-[#00ffd1] font-bold">Astro Static Engine</span>
        <span class="px-3 py-1.5 border border-[#00ffd1]/30 bg-[#101114] text-[9px] uppercase tracking-widest text-[#00ffd1] font-bold">Matter.js Physics</span>
        <span class="px-3 py-1.5 border border-[#00ffd1]/30 bg-[#101114] text-[9px] uppercase tracking-widest text-[#00ffd1] font-bold">No-Sphere Modules</span>
      </div>
    </div>

    <div class="lg:col-span-6 p-6 sm:p-10 md:p-16 bg-[#000000] flex flex-col justify-between">
      <div>
        <h3 class="text-[10px] font-black uppercase tracking-[0.4em] text-[#00ffd1] mb-2">Draggable Physics Sandbox</h3>
        <span class="text-[9px] font-mono uppercase text-[#8a909a] block mb-6">Grab and throw skills inside boundaries.</span>
        
        <PhysicsCanvas client:idle />
      </div>
    </div>

  </section>

  <section id="projects" class="py-20 px-4 xs:px-6 sm:px-10 md:px-24 bg-transparent z-10 relative">
    <div class="max-w-7xl mx-auto">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
        <div>
          <h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-[#00ffd1] mb-4 scramble-text" data-text="LEDGER // ARCHIVES">LEDGER // ARCHIVES</h2>
          <h3 class="text-3xl xs:text-5xl md:text-6xl font-extrabold uppercase font-display">Featured <br/> <span class="text-[#00ffd1]">Works</span></h3>
        </div>
        <div class="border-3 border-[#00ffd1] bg-black text-[#00ffd1] text-[10px] tracking-widest font-black uppercase px-4 py-2">
          TAB_INDEX_SYSTEM
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {projects.slice(0, 4).map((project, index) => (
          <div class="relative flex flex-col">
            
            <div class="flex">
              <div class="bg-[#00ffd1] text-black font-mono text-xs font-black px-4 py-2 border-t-3 border-x-3 border-[#00ffd1]">
                INDEX_0{index + 1}
              </div>
              <div class="bg-[#101114] text-[#8a909a] font-mono text-[9px] px-3 py-2 border-t-3 border-r-3 border-[#00ffd1]/20 flex items-center">
                {project.category}
              </div>
            </div>

            <a 
              href={`/project/${project.slug}`} 
              class="group cursor-pointer block border-3 border-[#00ffd1] p-4 bg-[#101114] shadow-[8px_8px_0px_#c5a059] hover:shadow-[12px_12px_0px_#00ffd1] hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all duration-300 flex-1 flex flex-col justify-between"
            >
              <div>
                <div class="aspect-[16/10] bg-[#000000] overflow-hidden mb-6 border-2 border-[#00ffd1]/20 relative">
                  <img 
                    src={project.image || "https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&fit=crop&q=80&w=1000"} 
                    alt={project.title} 
                    class="w-full h-full object-cover opacity-50 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 grayscale group-hover:grayscale-0" 
                  />
                  <div class="absolute inset-0 bg-[#000000]/80 flex items-center justify-center p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <span class="text-[9px] font-mono uppercase tracking-widest font-black border-b-3 border-[#00ffd1] pb-1 text-[#00ffd1]">Load Project Directory</span>
                  </div>
                </div>
                
                <h4 class="text-2xl font-extrabold uppercase font-display text-white mb-2 group-hover:text-[#00ffd1] transition-colors">{project.title}</h4>
                <p class="text-[#8a909a] text-xs font-sans leading-relaxed line-clamp-3">{project.description}</p>
              </div>

              <div class="mt-6 pt-4 border-t border-[#00ffd1]/20 flex justify-between items-center text-[10px] text-[#00ffd1]">
                <span>VIEW DIRECTORY</span>
                <span class="font-black">→</span>
              </div>
            </a>

          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a href="/projects" class="btn-neo">
          Explore Complete Database
        </a>
      </div>
    </div>
  </section>

  <section id="contact" class="py-20 px-4 xs:px-6 sm:px-10 md:px-24 bg-transparent z-10 relative">
    <div class="max-w-4xl mx-auto border-4 border-[#00ffd1] bg-[#101114] p-8 md:p-12 shadow-[8px_8px_0px_#ffffff]">
      
      <div class="flex items-center gap-2 mb-6">
        <div class="w-3 h-3 bg-[#00E676] rounded-full animate-pulse shadow-[0_0_8px_#00E676]"></div>
        <span class="text-[10px] font-black uppercase text-[#00ffd1] tracking-widest">Inbound Terminal Port</span>
      </div>

      <p class="text-3xl md:text-5xl font-extrabold tracking-tighter uppercase font-display mb-8 text-white">
        LET'S LAUNCH THE NEXT INSTANCE.
      </p>

      <div class="space-y-4 mb-10 text-xs font-mono text-[#8a909a] border-y border-[#00ffd1]/20 py-6">
        <div>C:\SHIBILI\PORTFOLIO&gt; pnpm run develop</div>
        <div class="text-white">&gt;&gt; Ready to collaborate on production applications, APIs, and micro-tools.</div>
        <div>C:\SHIBILI\PORTFOLIO&gt; pnpm run whatsapp-connect</div>
        <div class="text-[#00ffd1]">&gt;&gt; WA.ME/919037619447 (Active Direct Line)</div>
      </div>
       
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="btn-neo text-center flex-1">
          Initiate Contact Protocol
        </a>
        <a href="https://wa.me/919037619447" target="_blank" class="btn-neo-white text-center flex-1">
          WhatsApp Connection
        </a>
      </div>

    </div>
  </section>
</main>

<Footer />

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    gsap.to('.scramble-text', {
      scrollTrigger: {
        trigger: '#about',
        start: 'top 80%',
      },
      opacity: 1,
      duration: 1
    });
  };

  document.addEventListener('astro:page-load', initAnimations);
</script>