---
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import Loader from './Loader.astro';
import { projects } from '../data/projects';
import { Github, Linkedin, Twitter } from '@lucide/astro';

const featuredProjects = projects.filter(p => p.image).slice(0, 4);

const techStack = [
  { name: 'Python',     color: '#3b82f6', icon: '🐍' },
  { name: 'JavaScript', color: '#f59e0b', icon: '⚡' },
  { name: 'TypeScript', color: '#60a5fa', icon: '🔷' },
  { name: 'C++',        color: '#a78bfa', icon: '⚙️' },
  { name: 'Java',       color: '#f97316', icon: '☕' },
  { name: 'Flutter',    color: '#38bdf8', icon: '📱' },
  { name: 'Next.js',    color: '#ffffff', icon: '▲' },
  { name: 'Figma',      color: '#fb923c', icon: '🎨' },
];

const stats = [
  { num: '15+', label: 'repos', key: 'projects' },
  { num: '2+',  label: 'years', key: 'experience' },
  { num: '8',   label: 'langs', key: 'languages' },
  { num: '∞',   label: 'bugs_fixed', key: 'bugs' },
];
---

<Loader />

<main id="main-content" class="relative z-10 text-white overflow-x-hidden font-mono">
  <Navbar />

  <!-- ═══ HERO: Terminal Window ═══ -->
  <section id="hero" class="relative min-h-screen flex flex-col justify-center bg-transparent overflow-hidden">

    <!-- Top HUD line -->
    <div class="absolute top-0 left-0 right-0 h-px bg-green-500/20"></div>

    <div class="px-4 sm:px-8 md:px-16 pt-28 pb-16 relative z-10 max-w-7xl mx-auto w-full">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">

        <!-- LEFT: Terminal intro -->
        <div class="lg:col-span-7">
          <!-- Terminal window chrome -->
          <div class="terminal-window mb-8 hero-anim opacity-0">
            <div class="terminal-bar">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
              </div>
              <span class="text-[10px] text-white/30 tracking-widest">bash — ~/shibili-aman</span>
              <div></div>
            </div>
            <div class="terminal-body">
              <div class="term-line">
                <span class="text-green-400">shibili@dev</span><span class="text-white/40">:</span><span class="text-blue-400">~</span><span class="text-white/40">$</span>
                <span class="text-white ml-2">whoami</span>
              </div>
              <div class="term-line mt-2 text-green-300">Shibili Aman TK</div>

              <div class="term-line mt-3">
                <span class="text-green-400">shibili@dev</span><span class="text-white/40">:</span><span class="text-blue-400">~</span><span class="text-white/40">$</span>
                <span class="text-white ml-2">cat profile.json</span>
              </div>
              <div class="term-output mt-2">
                <span class="text-white/60">{"{"}</span><br/>
                <span class="pl-4"><span class="text-blue-300">"role"</span><span class="text-white/60">:</span> <span class="text-green-300">"Full-Stack Developer"</span><span class="text-white/60">,</span></span><br/>
                <span class="pl-4"><span class="text-blue-300">"status"</span><span class="text-white/60">:</span> <span class="text-green-300">"B.Tech CSE @ CEV"</span><span class="text-white/60">,</span></span><br/>
                <span class="pl-4"><span class="text-blue-300">"available"</span><span class="text-white/60">:</span> <span class="text-yellow-300">true</span><span class="text-white/60">,</span></span><br/>
                <span class="pl-4"><span class="text-blue-300">"building"</span><span class="text-white/60">:</span> <span class="text-green-300">"things that matter"</span></span><br/>
                <span class="text-white/60">{"}"}</span>
              </div>

              <div class="term-line mt-3">
                <span class="text-green-400">shibili@dev</span><span class="text-white/40">:</span><span class="text-blue-400">~</span><span class="text-white/40">$</span>
                <span class="cursor-blink ml-2">█</span>
              </div>
            </div>
          </div>

          <!-- Big name -->
          <div class="hero-anim opacity-0">
            <h1 class="text-[3.5rem] sm:text-[5rem] md:text-[7rem] font-black tracking-tighter leading-[0.85] uppercase">
              <span class="text-green-400">&lt;</span>Shibili<span class="text-green-400">/&gt;</span>
            </h1>
            <p class="text-zinc-400 text-base md:text-lg mt-4 leading-relaxed max-w-lg">
              Building scalable apps, automations, and UI experiences.<br/>
              <span class="text-green-400">// Open to internships &amp; collabs</span>
            </p>
          </div>

          <!-- Social links -->
          <div class="flex gap-4 mt-8 hero-anim opacity-0">
            <a href="https://github.com/LordSA" target="_blank"
               class="dev-btn group flex items-center gap-2 border border-green-500/30 px-4 py-2 hover:border-green-400 hover:bg-green-400/5 transition-all duration-300">
              <Github size={14} class="text-green-400" />
              <span class="text-[11px] tracking-widest text-green-400">GitHub</span>
            </a>
            <a href="https://www.linkedin.com/in/shibili-aman-tk" target="_blank"
               class="dev-btn group flex items-center gap-2 border border-blue-500/30 px-4 py-2 hover:border-blue-400 hover:bg-blue-400/5 transition-all duration-300">
              <Linkedin size={14} class="text-blue-400" />
              <span class="text-[11px] tracking-widest text-blue-400">LinkedIn</span>
            </a>
            <a href="https://x.com/shibiliii_aman" target="_blank"
               class="dev-btn group flex items-center gap-2 border border-white/20 px-4 py-2 hover:border-white/60 hover:bg-white/5 transition-all duration-300">
              <Twitter size={14} class="text-white/60" />
              <span class="text-[11px] tracking-widest text-white/60">Twitter</span>
            </a>
          </div>
        </div>

        <!-- RIGHT: Photo + status badge -->
        <div class="lg:col-span-5 flex flex-col items-center gap-6 hero-anim opacity-0">
          <div class="relative">
            <!-- Scanline green glow -->
            <div class="absolute inset-0 bg-green-500/10 blur-3xl rounded-full scale-150"></div>
            <!-- Photo in hex/square clip -->
            <div class="relative w-56 h-56 md:w-72 md:h-72 rounded-2xl overflow-hidden border border-green-500/20">
              <img src="/shibili.webp" alt="Shibili Aman TK"
                   class="w-full h-full object-cover object-center grayscale hover:grayscale-0 transition-all duration-700" />
              <!-- Green scan overlay -->
              <div class="absolute inset-0 bg-gradient-to-b from-green-900/20 via-transparent to-green-900/40 pointer-events-none"></div>
            </div>
            <!-- Corner brackets -->
            <div class="absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-green-400/60"></div>
            <div class="absolute top-0 right-0 w-6 h-6 border-t-2 border-r-2 border-green-400/60"></div>
            <div class="absolute bottom-0 left-0 w-6 h-6 border-b-2 border-l-2 border-green-400/60"></div>
            <div class="absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-green-400/60"></div>
          </div>

          <!-- Status bar -->
          <div class="w-full max-w-xs bg-black border border-green-500/20 px-4 py-3 rounded">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
              <span class="text-[10px] text-green-400 tracking-widest uppercase">Status: Available</span>
            </div>
            <div class="text-[10px] text-white/40 leading-relaxed">
              <span class="text-white/60">location:</span> Kerala, India<br/>
              <span class="text-white/60">commit:</span> <span class="text-green-300">3f9a21b</span> — "add coffee, ship code"
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="absolute bottom-0 left-0 right-0 bg-black/80 border-t border-green-500/10 px-6 py-3 grid grid-cols-4 gap-4 max-w-4xl">
      {stats.map(s => (
        <div class="text-center">
          <div class="text-green-400 font-black text-xl tracking-tighter">{s.num}</div>
          <div class="text-[9px] text-white/30 tracking-widest uppercase">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ ABOUT: Code Comment Style ═══ -->
  <section id="about" class="py-32 px-4 sm:px-8 md:px-16 bg-black border-t border-white/5">
    <div class="max-w-7xl mx-auto">

      <div class="reveal-block opacity-0 mb-16">
        <div class="text-[10px] text-green-500/60 tracking-widest mb-2">// section_01.about</div>
        <h2 class="text-4xl md:text-7xl font-black uppercase tracking-tighter text-white">
          <span class="text-green-400">def</span> who_am_i<span class="text-white/40">()</span>:
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Bio as docstring -->
        <div class="reveal-block opacity-0">
          <div class="code-block">
            <div class="code-block-bar">
              <span class="text-[10px] text-white/40">about.py</span>
            </div>
            <div class="code-body">
              <div class="code-line"><span class="text-white/30 select-none mr-4">1</span><span class="text-purple-400">"""</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">2</span><span class="text-zinc-300">CS student at College of Engineering</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">3</span><span class="text-zinc-300">Vadakara. Passionate about building</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">4</span><span class="text-zinc-300">scalable solutions, clean UIs, and</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">5</span><span class="text-zinc-300">automation tools that actually work.</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">6</span><span class="text-purple-400">"""</span></div>
              <div class="code-line mt-2"><span class="text-white/30 select-none mr-4">7</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">8</span><span class="text-blue-400">return</span> <span class="text-white">{`{`}</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">9</span><span class="pl-4 text-zinc-300"><span class="text-green-300">"focus"</span>: <span class="text-yellow-300">[</span><span class="text-green-300">"Web"</span>, <span class="text-green-300">"Bots"</span>, <span class="text-green-300">"UI"</span><span class="text-yellow-300">]</span>,</span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">10</span><span class="pl-4 text-zinc-300"><span class="text-green-300">"mode"</span>: <span class="text-green-300">"build → ship → iterate"</span></span></div>
              <div class="code-line"><span class="text-white/30 select-none mr-4">11</span><span class="text-white">{`}`}</span></div>
            </div>
          </div>
        </div>

        <!-- Tech stack as import statements -->
        <div class="reveal-block opacity-0">
          <div class="code-block">
            <div class="code-block-bar">
              <span class="text-[10px] text-white/40">stack.ts</span>
            </div>
            <div class="code-body">
              {techStack.map((t, i) => (
                <div class="code-line group cursor-default">
                  <span class="text-white/30 select-none mr-4 text-[11px]">{(i+1).toString().padStart(2,'0')}</span>
                  <span class="text-purple-400">import</span>
                  <span class="text-white/80 mx-1" style={`color: ${t.color}`}> {t.name} </span>
                  <span class="text-purple-400">from</span>
                  <span class="text-green-300 ml-1">'{t.name.toLowerCase()}'</span>
                  <span class="text-white/20 ml-2 text-[10px] group-hover:text-white/50 transition-colors">{t.icon}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROJECTS: File Explorer Style ═══ -->
  <section id="projects" class="py-32 px-4 sm:px-8 md:px-16 bg-black border-t border-white/5">
    <div class="max-w-7xl mx-auto">

      <div class="reveal-block opacity-0 mb-16">
        <div class="text-[10px] text-green-500/60 tracking-widest mb-2">// section_02.projects</div>
        <h2 class="text-4xl md:text-7xl font-black uppercase tracking-tighter text-white">
          <span class="text-blue-400">git</span> log <span class="text-white/30">--oneline</span>
        </h2>
      </div>

      <!-- Project cards as IDE tabs / file cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredProjects.map((project, i) => (
          <a href={`/project/${project.slug}`} class="project-card reveal-block opacity-0 group block border border-white/5 hover:border-green-500/30 transition-all duration-500 bg-zinc-950/50 overflow-hidden">

            <!-- File tab bar -->
            <div class="flex items-center gap-3 px-4 py-2.5 border-b border-white/5 bg-black/50">
              <div class="w-2 h-2 rounded-full bg-green-400/60 group-hover:bg-green-400 transition-colors"></div>
              <span class="text-[10px] text-white/40 group-hover:text-white/70 transition-colors tracking-widest">
                {project.slug}.{project.category.includes('Python') ? 'py' : project.category.includes('Game') ? 'java' : 'ts'}
              </span>
              <span class="ml-auto text-[9px] text-white/20 group-hover:text-green-400/60 transition-colors">0{i+1}</span>
            </div>

            <!-- Project image -->
            <div class="aspect-[16/9] overflow-hidden relative bg-zinc-900">
              <img src={project.image} alt={project.title}
                   class="w-full h-full object-cover opacity-60 grayscale group-hover:opacity-90 group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            </div>

            <!-- Code-style info block -->
            <div class="p-5">
              <div class="text-[10px] text-green-500/60 tracking-widest mb-1"># {project.category}</div>
              <h3 class="text-xl md:text-2xl font-bold uppercase tracking-tighter text-white mb-2 group-hover:text-green-300 transition-colors">{project.title}</h3>
              <p class="text-sm text-zinc-500 group-hover:text-zinc-300 transition-colors leading-relaxed line-clamp-2">{project.description}</p>
              <div class="mt-4 flex items-center gap-2 text-[10px] text-green-400/50 group-hover:text-green-400 transition-colors tracking-widest">
                <span>→ view_project()</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-12 reveal-block opacity-0">
        <a href="/projects" class="inline-flex items-center gap-3 border border-white/10 hover:border-green-500/40 hover:bg-green-400/5 px-6 py-3 transition-all duration-300 group">
          <span class="text-[11px] tracking-widest text-white/50 group-hover:text-green-400 transition-colors">ls ./projects --all</span>
          <span class="text-green-400 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT: Git Commit Style ═══ -->
  <section id="contact" class="py-32 px-4 sm:px-8 md:px-16 bg-black border-t border-white/5">
    <div class="max-w-5xl mx-auto">

      <div class="reveal-block opacity-0 mb-16">
        <div class="text-[10px] text-green-500/60 tracking-widest mb-2">// section_03.contact</div>
        <h2 class="text-4xl md:text-7xl font-black uppercase tracking-tighter">
          <span class="text-yellow-400">git commit</span><br/>
          <span class="text-green-300">-m "hire me"</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 reveal-block opacity-0">
        <!-- Left: terminal contact -->
        <div class="terminal-window">
          <div class="terminal-bar">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
            </div>
            <span class="text-[10px] text-white/30">contact.sh</span>
            <div></div>
          </div>
          <div class="terminal-body">
            <div class="term-line text-white/50">$ <span class="text-white">send_message --to shibili</span></div>
            <div class="mt-3 space-y-2">
              <div class="term-line"><span class="text-white/40">Email: </span><a href="mailto:shibili.dev@gmail.com" class="text-green-300 hover:text-green-200 transition-colors">shibili.dev@gmail.com</a></div>
              <div class="term-line"><span class="text-white/40">GitHub: </span><a href="https://github.com/LordSA" target="_blank" class="text-blue-300 hover:text-blue-200 transition-colors">@LordSA</a></div>
              <div class="term-line"><span class="text-white/40">LinkedIn: </span><a href="https://linkedin.com/in/shibili-aman-tk" target="_blank" class="text-blue-300 hover:text-blue-200 transition-colors">shibili-aman-tk</a></div>
              <div class="term-line"><span class="text-white/40">Twitter: </span><a href="https://x.com/shibiliii_aman" target="_blank" class="text-blue-300 hover:text-blue-200 transition-colors">@shibiliii_aman</a></div>
            </div>
            <div class="mt-4 term-line">
              <span class="text-green-400">✓</span> <span class="text-white/50">Message queued. Will respond within 24h.</span>
            </div>
            <div class="term-line mt-1">
              <span class="text-green-400">shibili@dev</span><span class="text-white/40">:~$</span>
              <span class="cursor-blink ml-1">█</span>
            </div>
          </div>
        </div>

        <!-- Right: CTA -->
        <div class="flex flex-col justify-center gap-8">
          <div>
            <div class="text-[10px] text-white/30 tracking-widest mb-4">// open_to</div>
            <div class="space-y-3">
              {['Internships', 'Freelance Projects', 'Open Source Collabs', 'Full-time Roles (2026)'].map(item => (
                <div class="flex items-center gap-3 text-sm text-zinc-300">
                  <span class="text-green-400 text-xs">✓</span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>
          <a href="/contact" class="group inline-flex items-center justify-center gap-3 bg-green-400 text-black font-bold text-xs uppercase tracking-widest px-8 py-4 hover:bg-green-300 transition-all duration-300">
            <span>Initialize Contact</span>
            <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</main>

<Footer />

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const init = () => {
    // Hero animations
    setTimeout(() => {
      gsap.to('.hero-anim', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        stagger: 0.15,
      });
    }, 1500);

    // Scroll reveals
    document.querySelectorAll('.reveal-block').forEach((el: any) => {
      gsap.fromTo(el,
        { y: 40, opacity: 0 },
        {
          scrollTrigger: { trigger: el, start: 'top 88%' },
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: 'power3.out',
        }
      );
    });

    // Typing cursor blink
    gsap.to('.cursor-blink', {
      opacity: 0,
      repeat: -1,
      yoyo: true,
      duration: 0.5,
      ease: 'steps(1)',
    });
  };

  document.addEventListener('astro:page-load', init);
</script>

<style>
  /* Terminal window */
  .terminal-window {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    overflow: hidden;
  }
  .terminal-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: #111;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .terminal-body {
    padding: 1.25rem 1.5rem;
    font-size: 0.78rem;
    line-height: 1.7;
  }
  .term-line {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .term-output {
    font-size: 0.75rem;
    line-height: 1.8;
    padding-left: 1rem;
    border-left: 2px solid rgba(74, 222, 128, 0.2);
  }

  /* Code block */
  .code-block {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    overflow: hidden;
  }
  .code-block-bar {
    padding: 0.5rem 1rem;
    background: #111;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .code-body {
    padding: 1rem;
    font-size: 0.75rem;
    line-height: 1.8;
  }
  .code-line {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  /* Project card */
  .project-card {
    border-radius: 4px;
  }

  /* Dev button */
  .dev-btn {
    border-radius: 2px;
  }

  /* Hero anim starts below */
  .hero-anim {
    transform: translateY(20px);
  }
</style>
