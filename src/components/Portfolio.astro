<Footer />

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initAnimations = () => {
    // Wait for loader
    setTimeout(() => {
      // Hero animations
      gsap.to('.gsap-hero-title', {
        opacity: 1,
        y: 0,
        duration: 1.2,
        ease: 'power3.out',
      });

      gsap.to('.gsap-hero-stagger', {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out',
        stagger: 0.1,
        delay: 0.2
      });
    }, 1500); // 1.5s is the loader time

    // Tech stack scroll animation
    gsap.to('.gsap-tech-item', {
      scrollTrigger: {
        trigger: '#about',
        start: 'top 70%',
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.05,
      ease: 'back.out(1.5)'
    });

    // Projects scroll animation
    gsap.to('.gsap-project-card', {
      scrollTrigger: {
        trigger: '#projects',
        start: 'top 60%',
      },
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: 'power3.out'
    });

    // Project image parallax
    gsap.utils.toArray('.project-img-container img').forEach((img: any) => {
      gsap.fromTo(img, 
        { y: '-10%', scale: 1.1 },
        {
          scrollTrigger: {
            trigger: img.parentElement,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
          y: '10%',
          ease: 'none'
        }
      );
    });

    // Text Scramble Effect
    const chars = '!<>-_\\/[]{}—=+*^?#________';
    gsap.utils.toArray('.scramble-text').forEach((el: any) => {
      ScrollTrigger.create({
        trigger: el,
        start: 'top 85%',
        onEnter: () => {
          const originalText = el.dataset.text;
          let iteration = 0;
          gsap.to({}, {
            duration: 1.5,
            onUpdate: () => {
              iteration += 1;
              el.innerText = originalText.split('').map((letter: string, index: number) => {
                if (index < iteration / 2) return originalText[index];
                return chars[Math.floor(Math.random() * chars.length)];
              }).join('');
            }
          });
        },
        once: true
      });
    });

    // 3D Tilt on Project Cards
    document.querySelectorAll('.gsap-project-card').forEach((card: any) => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -10;
        const rotateY = ((x - centerX) / centerX) * 10;
        
        gsap.to(card, {
          rotateX,
          rotateY,
          transformPerspective: 1000,
          ease: "power2.out",
          duration: 0.5
        });
      });
      
      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          ease: "power2.out",
          duration: 0.5
        });
      });
    });
  };

  document.addEventListener('astro:page-load', initAnimations);
</script>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    100% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 3s ease-in-out infinite alternate;
  }

  .secret-vault-section {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(26px);
    transition: max-height 0.65s ease, opacity 0.45s ease, transform 0.45s ease, padding-top 0.45s ease, padding-bottom 0.45s ease;
    border-top: 1px solid transparent;
    border-bottom: 1px solid transparent;
    padding-top: 0;
    padding-bottom: 0;
  }

  .secret-vault-section.is-open {
    max-height: 960px;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    border-top-color: rgba(255, 255, 255, 0.08);
    border-bottom-color: rgba(255, 255, 255, 0.08);
    padding-top: 2.5rem;
