---
---

<div id="loader" class="fixed inset-0 z-[100] bg-black flex items-center justify-center transition-all duration-[1500ms] ease-[cubic-bezier(0.85,0,0.15,1)] origin-center">
  <div class="flex flex-col items-center">
     <div class="relative mb-8 animate-logo-intro">
        <img src="/logo.png" alt="Logo" class="w-32 h-32 md:w-48 md:h-48 object-contain" />
        <div class="absolute inset-0 bg-white/10 blur-3xl rounded-full -z-10 animate-glow"></div>
     </div>
     <div class="w-64 h-[2px] bg-zinc-900 relative overflow-hidden rounded-full">
        <div class="absolute inset-0 bg-white animate-progress-fast"></div>
     </div>
     <div class="mt-6 text-[11px] uppercase tracking-[0.6em] text-zinc-500 font-medium font-sans animate-pulse">
       \/\/Loading\/\/
     </div>
  </div>
</div>

<script>
  const initLoader = () => {
    const loader = document.getElementById('loader');
    if (loader) {
      // Small timeout to ensure scale(5) transition from previous page (if any) is reset
      requestAnimationFrame(() => {
        loader.style.transition = 'none';
        loader.style.transform = 'scale(1)';
        loader.style.opacity = '1';
        loader.style.pointerEvents = 'auto';
        
        // Force reflow
        loader.offsetHeight;
        
        loader.style.transition = 'all 1500ms cubic-bezier(0.85, 0, 0.15, 1)';

        setTimeout(() => {
          loader.style.transform = 'scale(5)';
          loader.style.opacity = '0';
          loader.style.pointerEvents = 'none';
        }, 2000);
      });
    }
  };

  // Run on page load (covers both initial load and ClientRouter navigation)
  document.addEventListener('astro:page-load', initLoader);
</script>

<style>
  @keyframes progress-fast {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .animate-progress-fast {
    animation: progress-fast 2s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }

  @keyframes logo-intro {
    0% { transform: scale(0.9); opacity: 0; filter: blur(10px); }
    100% { transform: scale(1); opacity: 1; filter: blur(0px); }
  }
  .animate-logo-intro {
    animation: logo-intro 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes glow {
    0% { opacity: 0.1; transform: scale(0.8); }
    100% { opacity: 0.3; transform: scale(1.2); }
  }
  .animate-glow {
    animation: glow 2s ease-in-out infinite alternate;
  }
</style>