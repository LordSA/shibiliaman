---
import { Home, Briefcase, User, Mail, Send } from '@lucide/astro';
---

<nav class="fixed top-8 left-1/2 -translate-x-1/2 z-50 hidden md:flex px-6 py-3 rounded-full border border-white/10 bg-black/40 backdrop-blur-xl shadow-[0_8px_32px_0_rgba(0,0,0,0.8)] items-center gap-12 animate-nav-slidein transition-all duration-500 hover:border-white/20 hover:bg-black/60 group">
  <div class="flex items-center gap-3 pr-4 border-r border-white/10">
    <a href="/" class="flex items-center gap-2 group/logo hover:opacity-80 transition-all">
      <img src="/logo.png" alt="Shibili Aman Logo" class="w-6 h-6 object-contain grayscale group-hover/logo:grayscale-0 transition-all duration-500" />
      <span class="text-sm font-bold tracking-tighter uppercase whitespace-nowrap">Shibili Aman</span>
    </a>
  </div>
  
  <div class="flex gap-10 items-center uppercase text-[10px] font-bold tracking-[0.2em] text-zinc-400">
    <a href="/" class="hover:text-white transition-colors relative group/link">
      Home
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-white transition-all duration-300 group-hover/link:w-full"></span>
    </a>
    <a href="/projects" class="hover:text-white transition-colors relative group/link">
      Work
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-white transition-all duration-300 group-hover/link:w-full"></span>
    </a>
    <a href="/experience" class="hover:text-white transition-colors relative group/link">
      Experience
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-white transition-all duration-300 group-hover/link:w-full"></span>
    </a>
    <a href="/contact" class="hover:text-white transition-colors relative group/link">
      Contact
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-white transition-all duration-300 group-hover/link:w-full"></span>
    </a>
  </div>

  <div class="pl-4 border-l border-white/10">
    <a href="mailto:info@shibili.tech" class="text-[9px] uppercase tracking-[0.2em] py-2 px-4 bg-white text-black rounded-full font-bold hover:bg-zinc-200 transition-all active:scale-95 block whitespace-nowrap">
      Hire Me
    </a>
  </div>
</nav>

<nav class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 md:hidden w-[90%] max-w-sm">
  <div class="flex items-center justify-around bg-zinc-950 px-2 py-2 rounded-full border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.8)] relative">
    <a href="/" class="flex flex-col items-center gap-1 p-3 text-white/40 hover:text-white transition-colors">
      <Home size={18} stroke-width={2.5} />
    </a>
    <a href="/projects" class="flex flex-col items-center gap-1 p-3 text-white/40 hover:text-white transition-colors">
      <Briefcase size={18} stroke-width={2.5} />
    </a>
    <a href="/experience" class="flex flex-col items-center gap-1 p-3 text-white/40 hover:text-white transition-colors">
      <User size={18} stroke-width={2.5} />
    </a>
    <a href="/contact" class="flex flex-col items-center gap-1 p-3 text-white/40 hover:text-white transition-colors">
      <Mail size={18} stroke-width={2.5} />
    </a>
    <div class="w-px h-6 bg-white/5 mx-1"></div>
    <a href="https://t.me/shibili_offline" target="_blank" class="p-3 bg-white text-black rounded-full shadow-lg active:scale-90 transition-transform flex items-center justify-center">
      <Send size={16} stroke-width={2.5} />
    </a>
  </div>
</nav>

<style>
  @keyframes nav-slidein {
    from { 
      transform: translate(-50%, -30px); 
      opacity: 0;
      backdrop-filter: blur(0px);
    }
    to { 
      transform: translate(-50%, 0); 
      opacity: 1;
      backdrop-filter: blur(24px);
    }
  }
</style>