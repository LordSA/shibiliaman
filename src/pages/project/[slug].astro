---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { Github, ExternalLink, ArrowLeft } from '@lucide/astro';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Shibili Aman`}>
  <Navbar />
  <main class="bg-[#000000] min-h-screen pt-28 md:pt-40 pb-20 px-6 sm:px-10 md:px-24">
    <div class="max-w-6xl mx-auto">
      
      <a 
        href="/projects" 
        class="inline-flex items-center gap-2 border-3 border-[#00ffd1] bg-[#000000] text-[#00ffd1] px-5 py-2.5 font-mono text-[10px] uppercase tracking-widest transition-all mb-12 shadow-[4px_4px_0px_#c5a059] hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_#ffffff] active:translate-x-0 active:translate-y-0 active:shadow-none"
      >
        <ArrowLeft size={14} />
        <span>Directory Index</span>
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start mb-16">
        
        <div class="lg:col-span-7 space-y-8">
          <div class="border-b-4 border-[#00ffd1] pb-6">
            <span class="text-[#00ffd1] text-[10px] font-mono uppercase tracking-widest mb-3 block">
              Category: {project.category}
            </span>
            <h1 class="text-3xl md:text-5xl font-extrabold tracking-tighter text-white font-display uppercase leading-tight">
              {project.title}
            </h1>
          </div>

          <div class="border-4 border-[#00ffd1] p-6 md:p-8 bg-[#101114] shadow-[8px_8px_0px_#c5a059] font-sans">
            <p class="text-sm md:text-base text-white/90 leading-relaxed font-light whitespace-pre-line">
              {project.fullDescription || project.description}
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            {project.live && (
              <a 
                href={project.live} 
                target="_blank" 
                class="btn-neo text-center"
              >
                <ExternalLink size={14} class="mr-2" />
                Live Build
              </a>
            )}
            {project.github && (
              <a 
                href={`https://${project.github}`} 
                target="_blank" 
                class="btn-neo-white text-center"
              >
                <Github size={14} class="mr-2" />
                Repository
              </a>
            )}
          </div>
        </div>

        <div class="lg:col-span-5 relative">
          <div class="border-4 border-[#00ffd1] bg-[#101114] p-3 shadow-[8px_8px_0px_#c5a059] hover:shadow-[12px_12px_0px_#00ffd1] transition-all">
            <img 
              src={project.image || "https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&fit=crop&q=80&w=1000"} 
              alt={project.title} 
              class="w-full aspect-[4/5] object-cover grayscale hover:grayscale-0 transition-all duration-700"
            />
          </div>
        </div>

      </div>
    </div>
  </main>
  <Footer />
</Layout>
