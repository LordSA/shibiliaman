---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import {
  Github,
  ExternalLink,
  ArrowLeft,
  Calendar,
  Tag,
  Layers,
  Cpu,
} from "@lucide/astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const resolveUrl = (url: string | undefined | null) => {
  if (!url) return null;
  const trimmed = url.trim();
  if (!trimmed) return null;
  if (trimmed.startsWith("http://") || trimmed.startsWith("https://")) {
    return trimmed;
  }
  return `https://${trimmed}`;
};

let githubUrl = resolveUrl(project.github);
let liveUrl = resolveUrl(project.live);

if (project.link) {
  const resolvedLink = resolveUrl(project.link);
  if (resolvedLink) {
    const isGithub = resolvedLink.includes("github.com");
    if (isGithub) {
      if (!githubUrl) {
        githubUrl = resolvedLink;
      }
    } else {
      if (!liveUrl) {
        liveUrl = resolvedLink;
      }
    }
  }
}

const liveLabel = liveUrl && liveUrl.includes("linkedin.com") ? "View Project" : "Live Build";
---

<Layout title={`${project.title} | Shibili Aman`}>
  <Navbar />
  <main
    class="bg-[#050505] min-h-screen pt-28 md:pt-40 pb-32 px-4 sm:px-6 md:px-16 lg:px-24"
  >
    <div class="max-w-6xl mx-auto">
      <a
        href="/projects"
        data-astro-reload
        class="relative z-30 inline-flex items-center gap-3 text-zinc-500 hover:text-white transition-all mb-12 group text-xs uppercase tracking-[0.2em] font-mono border border-white/5 bg-zinc-950/40 px-4 py-2 rounded-full hover:border-white/10"
      >
        <ArrowLeft
          size={14}
          class="transition-transform group-hover:-translate-x-1"
        />
        <span>Back to Database</span>
      </a>

      <div class="border-b border-white/10 pb-8 mb-12">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse">
          </div>
          <span
            class="text-[9px] uppercase tracking-[0.3em] text-zinc-500 font-mono font-bold"
            >Project File: Loaded</span
          >
        </div>

        <h1
          class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tighter text-white uppercase leading-none mb-6"
        >
          {project.title}
        </h1>

        <div
          class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 pt-8 border-t border-white/5 font-mono text-[10px]"
        >
          <div
            class="p-4 bg-zinc-950/50 border border-white/5 rounded-xl flex items-center gap-3"
          >
            <Tag size={14} class="text-[#c5a059]" />
            <div>
              <span
                class="text-zinc-600 block uppercase text-[8px] tracking-widest"
                >Category</span
              >
              <span class="text-white uppercase font-bold"
                >{project.category}</span
              >
            </div>
          </div>

          <div
            class="p-4 bg-zinc-950/50 border border-white/5 rounded-xl flex items-center gap-3"
          >
            <Layers size={14} class="text-[#c5a059]" />
            <div>
              <span
                class="text-zinc-600 block uppercase text-[8px] tracking-widest"
                >Role</span
              >
              <span class="text-white uppercase font-bold">Lead Developer</span>
            </div>
          </div>

          <div
            class="p-4 bg-zinc-950/50 border border-white/5 rounded-xl flex items-center gap-3"
          >
            <Calendar size={14} class="text-[#c5a059]" />
            <div>
              <span
                class="text-zinc-600 block uppercase text-[8px] tracking-widest"
                >Release</span
              >
              <span class="text-white uppercase font-bold">2026 / Active</span>
            </div>
          </div>

          <div
            class="p-4 bg-zinc-950/50 border border-white/5 rounded-xl flex items-center gap-3"
          >
            <Cpu size={14} class="text-[#c5a059]" />
            <div>
              <span
                class="text-zinc-600 block uppercase text-[8px] tracking-widest"
                >Interface</span
              >
              <span class="text-white uppercase font-bold">Responsive Node</span
              >
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start mb-16">
        <div class="lg:col-span-7 space-y-8 relative z-30">
          <div
            class="p-6 md:p-8 bg-zinc-950/30 border border-white/5 rounded-2xl md:rounded-3xl font-sans"
          >
            <h3
              class="text-xs font-mono uppercase tracking-[0.2em] text-[#c5a059] mb-4 font-bold"
            >
              Description Ledger
            </h3>
            <p
              class="text-sm md:text-base text-zinc-400 leading-relaxed font-light whitespace-pre-line text-balance"
            >
              {project.fullDescription || project.description}
            </p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 relative z-30">
            {
              liveUrl && (
                <a
                  href={liveUrl}
                  target="_blank"
                  class="px-8 py-4 bg-white text-black font-bold font-mono text-xs uppercase tracking-widest hover:bg-zinc-200 transition-all flex items-center justify-center gap-2 rounded-xl"
                >
                  <ExternalLink size={14} />
                  {liveLabel}
                </a>
              )
            }
            {
              githubUrl && (
                <a
                  href={githubUrl}
                  target="_blank"
                  class="px-8 py-4 bg-zinc-950 text-white border border-white/10 hover:border-white/20 font-bold font-mono text-xs uppercase tracking-widest transition-all flex items-center justify-center gap-2 rounded-xl"
                >
                  <Github size={14} />
                  Source Code
                </a>
              )
            }
          </div>
        </div>

        <div class="lg:col-span-5 relative group">
          <div
            class="absolute -inset-4 bg-gradient-to-tr from-[#c5a059]/10 to-transparent blur-3xl rounded-[2.5rem] opacity-40"
          >
          </div>
          <div
            class="relative z-10 border border-white/10 bg-zinc-950/80 p-3 rounded-2xl md:rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.5)]"
          >
            <img
              src={project.image ||
                "https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&fit=crop&q=80&w=1000"}
              alt={project.title}
              class="w-full aspect-video object-cover rounded-xl md:rounded-2xl grayscale group-hover:grayscale-0 transition-all duration-700"
            />
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
