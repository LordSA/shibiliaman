---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { socialLinks } from '../data/contact';
import { ArrowUpRight } from '@lucide/astro';

---

<Layout title="Contact | Shibili Aman">
  <Navbar />
  <main class="bg-black min-h-screen pt-12 md:pt-32 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="mb-8 md:mb-20">
        <div class="flex items-center gap-2 md:gap-3 mb-4 md:mb-6">
          <div class="w-1.5 h-1.5 md:w-2 md:h-2 bg-white animate-pulse"></div>
          <span class="text-[8px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] text-zinc-500 font-bold tracking-widest">Signal established</span>
        </div>
        <h1 class="text-5xl md:text-8xl font-bold tracking-tighter uppercase leading-[0.9]">
          Let's <br/> <span class="text-zinc-800">Communicate</span>
        </h1>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-1 gap-12 border-t border-white/10 pt-8 md:pt-12">
        <!-- Contact Links -->
        <div class="space-y-8">
          <h2 class="text-[10px] uppercase tracking-widest text-zinc-600 mb-6 underline decoration-zinc-800 underline-offset-8">Available Nodes</h2>
          <div class="grid grid-cols-2 xs:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 md:gap-6">
            {socialLinks.map((social) => (
              <a 
                href={social.href} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="group p-4 bg-zinc-950/40 border border-white/5 hover:border-white/10 transition-all duration-300 block relative overflow-hidden rounded-lg md:rounded-xl"
              >
                <div class="flex justify-between items-start mb-4 md:mb-6">
                  <div class="p-1.5 bg-zinc-900 border border-white/5 text-zinc-500 group-hover:text-white transition-colors">
                    <social.icon size={14} />
                  </div>
                  <ArrowUpRight size={12} class="text-zinc-800 group-hover:text-white transition-colors" />
                </div>
                <div>
                  <h3 class="text-zinc-600 text-[8px] uppercase tracking-widest mb-1">{social.label}</h3>
                  <p class="text-white text-[10px] md:text-xs truncate">{social.handle}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Meta Info -->
        <div class="pt-8 md:pt-12 border-t border-white/5">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start">
            <div class="p-6 md:p-8 border border-white/5 bg-zinc-950/20 rounded-2xl md:rounded-3xl h-full">
              <h3 class="text-[9px] md:text-[10px] uppercase tracking-[0.4em] text-zinc-600 mb-6 font-bold">Location & Status</h3>
              <p class="text-lg md:text-xl text-zinc-400 font-light leading-relaxed font-sans">
                Based in <span class="text-white font-medium">Kerala, India</span>. <br/>
                Operating synchronized with <span class="text-white font-medium">IST (UTC+5:30)</span>.
              </p>
            </div>
            
            <div class="p-6 md:p-8 border border-white/5 bg-zinc-950/20 rounded-2xl md:rounded-3xl h-full">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-1 h-1 md:w-1.5 md:h-1.5 bg-zinc-500 animate-pulse"></div>
                <h3 class="text-[9px] md:text-[10px] uppercase tracking-[0.4em] text-zinc-600 font-bold">Current Availability</h3>
              </div>
              <p class="text-white text-[11px] md:text-base font-sans opacity-80 leading-relaxed">Open for selective collaborations, architectural consulting, and high-performance system design.</p>
            </div>

            <div class="p-6 md:p-8 border border-white/5 bg-zinc-950/20 rounded-2xl md:rounded-3xl h-full flex flex-col justify-between">
              <h3 class="text-[9px] md:text-[10px] uppercase tracking-[0.4em] text-zinc-600 mb-6 font-bold">System Ref</h3>
              <div class="text-[8px] md:text-[10px] text-zinc-700 leading-loose uppercase tracking-tighter">
                Ref: 77.105.108.105.108.105 / Status: Active <br/>
                Latency: <span class="text-zinc-500">Standard</span> <br/>
                Uptime: <span class="text-emerald-500/50">99.9%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
