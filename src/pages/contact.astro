---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { socialLinks } from '../data/contact';
import { ArrowUpRight } from '@lucide/astro';
---

<Layout title="Contact | Shibili Aman">
  <Navbar />
  <main class="bg-[#08080a] min-h-screen pt-24 md:pt-36 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      
      <div class="mb-12 md:mb-20">
        <div class="flex items-center gap-2 md:gap-3 mb-4 md:mb-6">
          <div class="w-2 h-2 bg-[#00E676] animate-pulse shadow-[0_0_8px_#00E676]"></div>
          <span class="text-[9px] uppercase tracking-[0.3em] text-[#c5a059] font-bold">Signal established</span>
        </div>
        <h1 class="text-4xl md:text-7xl font-extrabold tracking-tighter uppercase font-display leading-[0.95]">
          Let's <br/> <span class="text-[#c5a059]">Communicate</span>
        </h1>
      </div>

      <div class="grid grid-cols-1 gap-12 border-t border-[#c5a059]/20 pt-12">
        
        <div class="space-y-8">
          <h2 class="text-[10px] font-bold uppercase tracking-widest text-[#c5a059] mb-6 underline decoration-[#c5a059] decoration-2 underline-offset-8">Available Nodes</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
            {socialLinks.map((social) => {
              const IconComponent = social.icon;
              return (
                <a 
                  href={social.href} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="group p-5 bg-[#08080a] border-2 border-[#c5a059] shadow-[4px_4px_0px_#c5a059] hover:shadow-[6px_6px_0px_#c5a059] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all duration-200 block relative overflow-hidden"
                >
                  <div class="flex justify-between items-start mb-6">
                    <div class="p-2 border border-[#c5a059]/20 text-[#c5a059] bg-[#c5a059]/5 group-hover:bg-[#c5a059] group-hover:text-[#08080a] transition-all">
                      <IconComponent size={16} />
                    </div>
                    <ArrowUpRight size={14} class="text-[#c5a059]/40 group-hover:text-white transition-colors" />
                  </div>
                  <div>
                    <h3 class="text-[#8a857a] text-[8px] uppercase tracking-widest mb-2 font-bold">{social.label}</h3>
                    <p class="text-white text-xs truncate">{social.handle}</p>
                  </div>
                </a>
              );
            })}
          </div>
        </div>

        <div class="pt-12 border-t border-[#c5a059]/20">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
            
            <div class="p-6 md:p-8 border-2 border-[#c5a059] bg-[#08080a] shadow-[4px_4px_0px_#c5a059] flex flex-col justify-between">
              <h3 class="text-[9px] uppercase tracking-[0.4em] text-[#c5a059] mb-6 font-bold">Location & Status</h3>
              <p class="text-base text-[#8a857a] font-sans leading-relaxed">
                Based in <span class="text-white font-medium">Kerala, India</span>. <br/>
                Operating synchronized with <span class="text-white font-medium">IST (UTC+5:30)</span>.
              </p>
            </div>
            
            <div class="p-6 md:p-8 border-2 border-[#c5a059] bg-[#08080a] shadow-[4px_4px_0px_#c5a059] flex flex-col justify-between">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-1.5 h-1.5 bg-[#00E676] animate-pulse"></div>
                <h3 class="text-[9px] uppercase tracking-[0.4em] text-[#c5a059] font-bold">Availability</h3>
              </div>
              <p class="text-white text-xs md:text-sm font-sans opacity-80 leading-relaxed">Open for selective collaborations, architectural consulting, and high-performance system design.</p>
            </div>

            <div class="p-6 md:p-8 border-2 border-[#c5a059] bg-[#08080a] shadow-[4px_4px_0px_#c5a059] flex flex-col justify-between">
              <h3 class="text-[9px] uppercase tracking-[0.4em] text-[#c5a059] mb-6 font-bold">System Status</h3>
              <div class="text-[9px] text-[#8a857a] leading-loose uppercase tracking-widest">
                REF: SHIBILI.TECH / ONLINE <br/>
                LATENCY: <span class="text-[#00E676]">MINIMAL</span> <br/>
                UPTIME: <span class="text-[#00E676]">99.99%</span>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </main>
  <Footer />
</Layout>
