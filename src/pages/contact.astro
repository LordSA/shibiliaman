---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { socialLinks } from '../data/contact';
import { ArrowUpRight } from '@lucide/astro';
---

<Layout title="Contact | Shibili Aman">
  <Navbar />
  <main class="bg-[#000000] min-h-screen pt-28 md:pt-36 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      
      <div class="mb-12 border-b-4 border-[#00ffd1] pb-8">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-3 h-3 bg-[#00E676] rounded-full animate-pulse shadow-[0_0_8px_#00E676]"></div>
          <span class="text-[10px] uppercase tracking-widest text-[#00ffd1] font-black">Connection Established</span>
        </div>
        <h1 class="text-4xl md:text-7xl font-extrabold uppercase font-display leading-[0.95] text-white">
          LET'S <br/> <span class="text-[#00ffd1]">COMMUNICATE</span>
        </h1>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <div class="lg:col-span-8 space-y-8">
          <h2 class="text-[10px] font-black uppercase tracking-widest text-[#00ffd1] mb-6 border-b-2 border-[#00ffd1]/20 pb-2">Active Communication Channels</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            {socialLinks.map((social) => {
              const IconComponent = social.icon;
              return (
                <div class="relative flex flex-col">
                  <div class="flex">
                    <div class="bg-[#00ffd1] text-black font-mono text-[9px] font-black px-3 py-1 border-t-3 border-x-3 border-[#00ffd1]">
                      {social.label}
                    </div>
                  </div>
                  <a 
                    href={social.href} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="group p-5 bg-[#101114] border-3 border-[#00ffd1] shadow-[4px_4px_0px_#ffffff] hover:shadow-[8px_8px_0px_#c5a059] hover:translate-x-[-4px] hover:translate-y-[-4px] transition-all duration-200 block flex-1 flex flex-col justify-between"
                  >
                    <div class="flex justify-between items-start mb-6">
                      <div class="p-2 border-2 border-[#00ffd1] text-[#00ffd1] bg-black group-hover:bg-[#00ffd1] group-hover:text-black transition-all">
                        <IconComponent size={16} />
                      </div>
                      <ArrowUpRight size={14} class="text-[#00ffd1]/40 group-hover:text-white transition-colors" />
                    </div>
                    <div>
                      <p class="text-white text-xs font-black truncate">{social.handle}</p>
                    </div>
                  </a>
                </div>
              );
            })}
          </div>
        </div>

        <div class="lg:col-span-4 space-y-8">
          <h2 class="text-[10px] font-black uppercase tracking-widest text-[#00ffd1] mb-6 border-b-2 border-[#00ffd1]/20 pb-2">System Directory</h2>
          
          <div class="border-3 border-[#00ffd1] bg-[#101114] p-6 shadow-[6px_6px_0px_#c5a059] space-y-6">
            <div>
              <span class="text-[9px] uppercase tracking-widest text-[#8a909a] block mb-2">Location & Coordinates</span>
              <p class="text-xs text-white leading-relaxed font-bold">
                KERALA, INDIA <br/>
                IST timezone (UTC+5:30)
              </p>
            </div>
            
            <div class="border-t border-[#00ffd1]/20 pt-6">
              <span class="text-[9px] uppercase tracking-widest text-[#8a909a] block mb-2">Operation Status</span>
              <p class="text-xs text-white leading-relaxed font-bold">
                AVAILABLE FOR SCALE WORK & ARCHITECT CONSULTATIONS.
              </p>
            </div>

            <div class="border-t border-[#00ffd1]/20 pt-6">
              <span class="text-[9px] uppercase tracking-widest text-[#8a909a] block mb-2">Network Reference</span>
              <div class="text-[9px] text-[#00ffd1] leading-loose uppercase tracking-widest">
                VERIFIED HOST: SHIBILI.TECH <br/>
                LATENCY: MINIMAL <br/>
                UPTIME: 99.99%
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
  <Footer />
</Layout>
