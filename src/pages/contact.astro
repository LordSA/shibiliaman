---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { socialLinks } from '../data/contact';
import { Mail, MessageCircle, ArrowUpRight } from '@lucide/astro';

---

<Layout title="Contact | Shibili Aman">
  <CustomCursor />
  <Navbar />
  <main class="bg-black min-h-screen pt-32 pb-20 px-6 sm:px-10 md:px-24 overflow-hidden relative">
    <!-- Background Accents -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/5 blur-[120px] rounded-full -mr-64 -mt-64"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-white/5 blur-[120px] rounded-full -ml-64 -mb-64"></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="mb-16 md:mb-24 border-l-2 border-white/10 pl-8">
        <h2 class="text-[10px] uppercase tracking-[0.6em] text-zinc-600 mb-6 font-bold">Transmission Protocol</h2>
        <h1 class="text-6xl md:text-9xl font-bold uppercase tracking-tighter leading-none mb-4">Get In <br/> <span class="text-zinc-800">Touch</span></h1>
        <p class="text-zinc-500 text-lg md:text-xl font-light max-w-xl">Whether it's a new project, a technical question, or just to say hi — I'm always open to new connections.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
        <!-- Contact Methods -->
        <div class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {socialLinks.map((social) => (
              <a href={social.href} target="_blank" rel="noopener noreferrer" class="group p-8 bg-zinc-950/50 border border-white/5 rounded-3xl hover:border-white/20 transition-all duration-500 hover:bg-zinc-900/50 block relative overflow-hidden">
                <div class="absolute top-4 right-4 text-zinc-800 group-hover:text-white transition-colors">
                    <ArrowUpRight size={20} />
                </div>
                <div class="mb-4 p-3 bg-zinc-900 inline-block rounded-2xl border border-white/5 text-zinc-500 group-hover:text-white transition-colors">
                  <social.icon size={24} />
                </div>
                <h3 class="text-zinc-500 text-[10px] uppercase tracking-widest mb-1">{social.label}</h3>
                <p class="text-white font-medium text-sm truncate">{social.handle}</p>
              </a>
            ))}
          </div>

          <a href="mailto:info@shibili.tech" class="flex items-center justify-between p-10 bg-white text-black rounded-[2.5rem] hover:bg-zinc-200 transition-all font-bold group">
            <div class="flex items-center gap-6">
               <div class="p-4 bg-black/5 rounded-2xl">
                 <Mail size={32} />
               </div>
               <div class="text-left">
                 <span class="text-[10px] uppercase tracking-widest block mb-1 opacity-60">Primary Email</span>
                 <p class="text-xl md:text-2xl tracking-tighter">info@shibili.tech</p>
               </div>
            </div>
            <ArrowUpRight size={32} class="opacity-20 group-hover:opacity-100 transition-opacity" />
          </a>
        </div>

        <!-- Fun Fact / Status -->
        <div class="lg:pt-20">
          <div class="p-12 border border-white/5 rounded-[3rem] bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.03)_0%,_transparent_100%)] relative">
            <div class="absolute -top-6 -left-6 w-12 h-12 bg-zinc-900 border border-white/10 rounded-2xl flex items-center justify-center animate-bounce text-white">
                <MessageCircle size={24} />
            </div>
            <h3 class="text-[10px] uppercase tracking-[0.4em] text-zinc-600 mb-8 font-bold">Standard Operating Status</h3>
            <div class="space-y-8">
                <div>
                   <p class="text-3xl font-light text-zinc-400 leading-tight">
                     Currently based in <span class="text-white italic">Kerala, India</span>. <br/>
                     Operating in <span class="text-white underline decoration-zinc-800 underline-offset-8">Ghost Mode</span> for deep work but always reachable via digital signals.
                   </p>
                </div>
                <div class="flex items-center gap-4 py-6 border-y border-white/5">
                    <div class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_15px_rgba(16,185,129,0.5)]"></div>
                    <span class="text-xs uppercase tracking-widest text-zinc-500 font-bold">Available for New Projects</span>
                </div>
                <p class="text-zinc-600 text-sm italic font-light">
                    Expected Response Time: 2-12 Hours
                </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
