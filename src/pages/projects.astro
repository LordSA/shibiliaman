---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';

---

<Layout title="Projects | Shibili Aman">
  <Navbar />
  <main class="bg-black min-h-screen pt-12 md:pt-32 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="mb-8 md:mb-24 px-4 border-l-2 border-white/10">
        <h2 class="text-[8px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] text-zinc-600 mb-2 md:mb-4 font-bold">Comprehensive Works</h2>
        <h1 class="text-5xl md:text-8xl font-bold uppercase tracking-tighter leading-none">Library of <br/> <span class="text-zinc-800">Projects</span></h1>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {projects.map((project) => (
          <a href={`/project/${project.slug}`} class="group cursor-pointer block border border-white/5 hover:border-white/10 p-4 rounded-2xl md:rounded-3xl bg-zinc-950/30 transition-all duration-500">
            <div class="aspect-[16/10] bg-zinc-900 rounded-xl overflow-hidden mb-5 border border-white/5 relative">
              <img src={project.image || "https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&fit=crop&q=80&w=1000"} alt={project.title} class="w-full h-full object-cover opacity-50 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000 md:grayscale md:hover:grayscale-0" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                 <span class="text-[8px] uppercase tracking-widest font-bold border-b border-white pb-1">Open Module</span>
              </div>
            </div>
            <div class="px-1">
              <span class="text-[8px] uppercase tracking-[0.2em] text-zinc-600 mb-2 block">{project.category}</span>
              <h4 class="text-lg md:text-xl font-bold uppercase tracking-tight mb-2 group-hover:text-zinc-300 transition-colors">{project.title}</h4>
              <p class="text-zinc-500 text-[10px] md:text-xs font-light line-clamp-2 leading-relaxed font-sans">{project.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
