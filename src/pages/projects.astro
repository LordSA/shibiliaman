---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Projects | Shibili Aman">
  <Navbar />
  <main class="bg-[#08080a] min-h-screen pt-24 md:pt-36 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      
      <div class="mb-12 md:mb-20 px-6 border-l-4 border-[#c5a059]">
        <h2 class="text-[9px] uppercase tracking-[0.3em] text-[#c5a059] mb-2 font-bold font-mono">Comprehensive Works</h2>
        <h1 class="text-4xl md:text-7xl font-extrabold uppercase font-display leading-none text-white">Library Of <br/> <span class="text-[#c5a059]">Projects</span></h1>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project, index) => (
          <a href={`/project/${project.slug}`} class="group cursor-pointer block border-2 border-[#c5a059] p-4 bg-[#08080a] shadow-[4px_4px_0px_#c5a059] hover:shadow-[6px_6px_0px_#c5a059] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all duration-300">
            <div class="aspect-[16/10] bg-[#08080a] overflow-hidden mb-5 border border-[#c5a059]/20 relative">
              <img src={project.image || "https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&fit=crop&q=80&w=1000"} alt={project.title} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 grayscale group-hover:grayscale-0" />
              <div class="absolute top-3 left-3 bg-[#08080a] border border-[#c5a059] text-[#c5a059] font-mono text-[10px] px-2 py-0.5 font-bold">
                {index < 9 ? `0${index + 1}` : index + 1}
              </div>
              <div class="absolute inset-0 bg-[#08080a]/80 flex items-center justify-center p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                 <span class="text-[9px] font-mono uppercase tracking-widest font-bold border-b border-[#c5a059] pb-1 text-[#c5a059]">Open Module</span>
              </div>
            </div>
            <div class="px-1">
              <span class="text-[8px] font-mono uppercase tracking-[0.2em] text-[#c5a059] mb-2 block">{project.category}</span>
              <h4 class="text-lg md:text-xl font-bold uppercase font-display text-white mb-2 group-hover:text-[#c5a059] transition-colors">{project.title}</h4>
              <p class="text-[#8a857a] text-xs font-sans line-clamp-2 leading-relaxed">{project.description}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </main>
  <Footer />
</Layout>
