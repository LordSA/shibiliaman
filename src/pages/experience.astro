---
import Layout from '../layouts/Layout.astro';
import { experiences } from '../data/experience';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Briefcase, Calendar } from '@lucide/astro';
---

<Layout title="Experience | Shibili Aman">
  <Navbar />
  <main class="bg-[#08080a] min-h-screen pt-24 md:pt-36 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      
      <div class="mb-12 md:mb-24 px-6 border-l-4 border-[#c5a059]">
        <h2 class="text-[9px] uppercase tracking-[0.3em] text-[#c5a059] mb-2 font-bold font-mono">Journey & Growth</h2>
        <h1 class="text-4xl md:text-7xl font-extrabold uppercase font-display leading-none text-white">Career <br/> <span class="text-[#c5a059]">History</span></h1>
      </div>

      <div class="space-y-16 md:space-y-24">
        {experiences.map((exp) => (
          <div class="relative">
            
            <div class="flex items-center gap-6 mb-8">
              <div class="w-14 h-14 md:w-16 md:h-16 bg-[#08080a] border-2 border-[#c5a059] flex items-center justify-center p-3 shadow-[4px_4px_0px_#c5a059]">
                <Briefcase size={24} class="text-[#c5a059]" />
              </div>
              <div>
                <h2 class="text-2xl md:text-4xl font-extrabold uppercase font-display leading-none text-white">
                  {exp.company}
                </h2>
                <div class="flex items-center gap-2 mt-2">
                  <div class="w-1.5 h-1.5 bg-[#00E676] animate-pulse"></div>
                  <p class="text-[8px] uppercase tracking-[0.3em] text-[#8a857a] font-bold">Node Identity Verified</p>
                </div>
              </div>
            </div>

            <div class="relative ml-7 md:ml-8 pl-8 md:pl-12 border-l-2 border-[#c5a059]/20 space-y-12 md:space-y-16">
              {exp.positions.map((pos) => (
                <div class="relative">
                  <div class="absolute -left-[38px] md:-left-[54px] top-2 w-3.5 h-3.5 bg-[#08080a] border-2 border-[#c5a059] z-20 flex items-center justify-center">
                     <div class="w-1 h-1 bg-[#c5a059]"></div>
                  </div>

                  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 md:gap-12">
                    <div class="lg:col-span-1">
                      <div class="sticky top-40">
                        <span class="text-[8px] uppercase tracking-[0.3em] text-[#c5a059] block mb-2 font-bold">Timeframe</span>
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 border border-[#c5a059]/20 bg-[#08080a] text-[#8a857a] text-[10px]">
                          <Calendar size={12} class="text-[#c5a059]" />
                          <span class="font-medium tracking-tight italic">{pos.period}</span>
                        </div>
                      </div>
                    </div>

                    <div class="lg:col-span-3">
                      <div class="mb-6">
                        <h3 class="text-xl md:text-3xl font-bold uppercase font-display mb-3 text-white leading-tight">
                          {pos.role}
                        </h3>
                        <div class="flex flex-wrap gap-2">
                           {pos.tags.map((tag) => (
                             <span class="px-2 py-1 border border-[#c5a059]/30 bg-[#08080a] text-[8px] uppercase tracking-[0.15em] text-[#c5a059] font-bold hover:border-[#c5a059] hover:bg-[#c5a059] hover:text-[#08080a] transition-all duration-200">
                               {tag}
                             </span>
                           ))}
                        </div>
                      </div>

                      <div class="space-y-6">
                        <p class="text-[#8a857a] text-sm md:text-base font-sans leading-relaxed max-w-3xl">
                          {pos.description}
                        </p>

                        {pos.achievements && (
                          <div class="pt-6 border-t border-[#c5a059]/20">
                            <h4 class="text-[8px] uppercase tracking-[0.4em] text-[#c5a059] mb-4 font-bold italic">Core Achievements</h4>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                              {pos.achievements.map((item) => (
                                <div class="flex items-start gap-3 p-4 border border-[#c5a059]/20 bg-[#08080a] hover:border-[#c5a059]/50 transition-colors">
                                  <div class="mt-1 w-3.5 h-3.5 border border-[#c5a059] flex items-center justify-center flex-shrink-0">
                                    <div class="w-1 h-1 bg-[#c5a059]"></div>
                                  </div>
                                  <span class="text-white text-xs md:text-sm font-sans leading-relaxed">{item}</span>
                                </div>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>

          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
