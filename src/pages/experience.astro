---
import Layout from '../layouts/Layout.astro';
import { experiences } from '../data/experience';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Briefcase, MapPin, Calendar, CheckCircle2 } from '@lucide/astro';

---

<Layout title="Experience | Shibili Aman">
  <Navbar />
  <main class="bg-black min-h-screen pt-12 md:pt-32 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="mb-8 md:mb-24 px-4 border-l-2 border-white/10">
        <h2 class="text-[8px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] text-zinc-600 mb-2 md:mb-4 font-bold">Journey & Growth</h2>
        <h1 class="text-5xl md:text-8xl font-bold uppercase tracking-tighter leading-none">Career <br/> <span class="text-zinc-800">History</span></h1>
      </div>

      <div class="space-y-12 md:space-y-20">
        {experiences.map((exp) => (
          <div class="group relative">
            <div class="relative z-10">
              <div class="flex items-center gap-6 mb-12">
                <div class="w-16 h-16 md:w-20 md:h-20 bg-zinc-950 border border-white/10 rounded-2xl flex items-center justify-center p-3 group-hover:border-white/20 transition-all duration-500 shadow-2xl">
                  <Briefcase size={32} class="text-zinc-600 group-hover:text-white transition-colors duration-500" />
                </div>
                <div>
                  <h2 class="text-3xl md:text-5xl font-bold uppercase tracking-tight leading-none group-hover:text-white transition-colors">
                    {exp.company}
                  </h2>
                  <div class="flex items-center gap-3 mt-3">
                    <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                    <p class="text-[10px] md:text-xs uppercase tracking-[0.4em] text-zinc-500 font-bold">Node Identity Verified</p>
                  </div>
                </div>
              </div>

              <div class="relative ml-8 md:ml-10 pl-10 md:pl-16 border-l-2 border-white/5 space-y-16 md:space-y-24">
                {exp.positions.map((pos, idx) => (
                  <div class="relative">
                    <div class="absolute -left-[51px] md:-left-[75px] top-2 w-6 h-6 rounded-full bg-black border-2 border-white/10 group-hover:border-white/30 transition-all duration-500 z-20 flex items-center justify-center">
                       <div class="w-2 h-2 rounded-full bg-zinc-900 group-hover:bg-emerald-500 transition-all duration-500 shadow-[0_0_15px_rgba(16,185,129,0)] group-hover:shadow-[0_0_15px_rgba(16,185,129,0.5)]"></div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 md:gap-12">
                      <div class="lg:col-span-1">
                        <div class="sticky top-40">
                          <span class="text-[9px] md:text-[10px] uppercase tracking-[0.4em] text-zinc-600 block mb-4 font-bold">Timeframe</span>
                          <div class="inline-flex items-center gap-3 px-4 py-2 bg-zinc-950 border border-white/5 rounded-full text-zinc-400 group-hover:border-white/10 transition-all">
                            <Calendar size={14} class="text-zinc-600" />
                            <span class="text-xs md:text-sm font-medium tracking-tight italic">{pos.period}</span>
                          </div>
                        </div>
                      </div>

                      <div class="lg:col-span-3">
                        <div class="mb-8">
                          <h3 class="text-2xl md:text-5xl font-bold uppercase tracking-tighter mb-4 text-white group-hover:text-white transition-colors leading-[0.9]">
                            {pos.role}
                          </h3>
                          <div class="flex flex-wrap gap-2">
                             {pos.tags.map((tag) => (
                               <span class="px-3 py-1.5 bg-zinc-950 border border-white/5 rounded-lg text-[8px] md:text-[10px] uppercase tracking-[0.2em] text-zinc-500 font-bold hover:border-emerald-500/30 hover:text-emerald-500 transition-all duration-300">
                                 {tag}
                               </span>
                             ))}
                          </div>
                        </div>

                        <div class="space-y-8">
                          <p class="text-zinc-400 text-lg md:text-2xl font-light leading-relaxed font-sans max-w-4xl">
                            {pos.description}
                          </p>

                          {pos.achievements && (
                            <div class="pt-10 border-t border-white/5">
                              <h4 class="text-[10px] uppercase tracking-[0.5em] text-zinc-600 mb-8 font-bold italic">Core Achievements</h4>
                              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                {pos.achievements.map((item) => (
                                  <div class="flex items-start gap-4 p-5 bg-zinc-950/50 border border-white/5 rounded-2xl hover:border-white/10 transition-all group/item">
                                    <div class="mt-1 w-5 h-5 rounded-full border border-zinc-800 flex items-center justify-center flex-shrink-0 group-hover/item:border-emerald-500/50 transition-colors">
                                      <div class="w-1.5 h-1.5 rounded-full bg-zinc-800 group-hover/item:bg-emerald-500 transition-colors"></div>
                                    </div>
                                    <span class="text-zinc-500 text-sm md:text-base font-light font-sans group-hover/item:text-zinc-300 transition-colors leading-relaxed">{item}</span>
                                  </div>
                                ))}
                              </div>
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
