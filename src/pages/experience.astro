---
import Layout from '../layouts/Layout.astro';
import { experiences } from '../data/experience';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { Briefcase, MapPin, Calendar, CheckCircle2 } from '@lucide/astro';

---

<Layout title="Experience | Shibili Aman">
  <CustomCursor />
  <Navbar />
  <main class="bg-black min-h-screen pt-32 pb-20 px-6 sm:px-10 md:px-24">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 md:mb-24 px-4 border-l border-white/10 text-right">
        <h2 class="text-[10px] uppercase tracking-[0.4em] text-zinc-600 mb-6 font-bold">Journey & Growth</h2>
        <h1 class="text-5xl md:text-8xl font-bold uppercase tracking-tighter">My <br/> <span class="text-zinc-800">Experience</span></h1>
      </div>

      <div class="space-y-12">
        {experiences.map((exp) => (
          <div class="group relative bg-zinc-950/50 border border-white/5 p-8 rounded-[2.5rem] hover:border-white/20 transition-all duration-700 hover:bg-zinc-900/40">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
              <div class="md:col-span-1 border-r border-white/5 pb-6">
                <span class="text-[10px] uppercase tracking-[0.4em] text-zinc-600 block mb-4">Duration</span>
                <div class="flex items-center gap-3 text-zinc-400">
                  <Calendar size={18} />
                  <span class="text-sm font-light italic">{exp.period}</span>
                </div>
              </div>
              
              <div class="md:col-span-3">
                <div class="flex flex-wrap justify-between items-start mb-6 gap-4">
                  <div>
                    <h2 class="text-3xl font-bold uppercase tracking-tighter mb-2 group-hover:text-zinc-200 transition-colors">
                      {exp.role}
                    </h2>
                    <p class="text-lg font-light text-zinc-400 italic">@ {exp.company}</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {exp.tags.map((tag) => (
                      <span class="px-3 py-1 bg-zinc-900 border border-white/10 rounded-full text-[9px] uppercase tracking-widest text-zinc-500 font-bold group-hover:border-white/30 group-hover:text-zinc-300 transition-all">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <p class="text-zinc-500 text-lg font-light mb-8 max-w-3xl leading-relaxed">
                  {exp.description}
                </p>

                {exp.achievements && (
                  <div class="space-y-4 pt-4 border-t border-white/5">
                    <span class="text-[10px] uppercase tracking-[0.4em] text-zinc-600 block mb-4 font-bold">Key Impacts</span>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      {exp.achievements.map((item) => (
                        <li class="flex items-start gap-3 text-zinc-400 text-sm font-light">
                          <CheckCircle2 size={16} class="mt-1 text-emerald-600 flex-shrink-0" />
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
