---
import Layout from '../layouts/Layout.astro';
import { experiences } from '../data/experience';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Briefcase, Calendar } from '@lucide/astro';
---

<Layout title="Experience | Shibili Aman">
  <Navbar />
  <main class="bg-[#000000] min-h-screen pt-28 md:pt-36 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      
      <div class="mb-12 border-b-4 border-[#00ffd1] pb-8">
        <h2 class="text-[10px] font-black uppercase tracking-widest text-[#00ffd1] mb-2 font-mono">JOURNAL // COMMIT_HISTORY</h2>
        <h1 class="text-4xl md:text-7xl font-extrabold uppercase font-display leading-none text-white">CAREER <br/> <span class="text-[#00ffd1]">LEDGER</span></h1>
      </div>

      <div class="space-y-16">
        {experiences.map((exp) => (
          <div class="relative">
            
            <div class="flex items-center gap-6 mb-8">
              <div class="w-14 h-14 bg-[#101114] border-3 border-[#00ffd1] flex items-center justify-center shadow-[4px_4px_0px_#ffffff]">
                <Briefcase size={22} class="text-[#00ffd1]" />
              </div>
              <div>
                <h2 class="text-2xl md:text-3xl font-extrabold uppercase font-display leading-none text-white">
                  {exp.company}
                </h2>
                <div class="flex items-center gap-2 mt-2">
                  <div class="w-1.5 h-1.5 bg-[#00E676] animate-pulse"></div>
                  <p class="text-[9px] uppercase tracking-widest text-[#8a909a] font-bold font-mono">Node Index Verified</p>
                </div>
              </div>
            </div>

            <div class="relative ml-7 pl-8 md:pl-12 border-l-4 border-dashed border-[#00ffd1]/30 space-y-12">
              {exp.positions.map((pos) => (
                <div class="relative">
                  
                  <div class="absolute -left-[42px] top-2 w-5 h-5 bg-[#000000] border-3 border-[#00ffd1] z-20 flex items-center justify-center shadow-[2px_2px_0px_#c5a059]">
                     <div class="w-1.5 h-1.5 bg-[#00ffd1]"></div>
                  </div>

                  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
                    
                    <div class="lg:col-span-3">
                      <div class="sticky top-40">
                        <span class="text-[9px] uppercase tracking-widest text-[#00ffd1] block mb-2 font-bold font-mono">Timestamp</span>
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 border-2 border-[#00ffd1]/20 bg-[#101114] text-[#8a909a] text-[10px]">
                          <Calendar size={12} class="text-[#00ffd1]" />
                          <span class="font-bold tracking-tight">{pos.period}</span>
                        </div>
                      </div>
                    </div>

                    <div class="lg:col-span-9 border-3 border-[#00ffd1] bg-[#101114] p-6 shadow-[6px_6px_0px_#c5a059] hover:shadow-[8px_8px_0px_#00ffd1] hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all">
                      <div class="mb-4">
                        <h3 class="text-xl md:text-2xl font-black uppercase font-display mb-3 text-white">
                          {pos.role}
                        </h3>
                        <div class="flex flex-wrap gap-2">
                           {pos.tags.map((tag) => (
                             <span class="px-2 py-1 border border-[#00ffd1]/30 bg-[#000000] text-[9px] uppercase tracking-widest text-[#00ffd1] font-bold">
                               {tag}
                             </span>
                           ))}
                        </div>
                      </div>

                      <div class="space-y-6">
                        <p class="text-[#8a909a] text-xs md:text-sm font-sans leading-relaxed">
                          {pos.description}
                        </p>

                        {pos.achievements && (
                          <div class="pt-6 border-t border-[#00ffd1]/20">
                            <h4 class="text-[9px] uppercase tracking-widest text-[#c5a059] mb-4 font-bold italic font-mono">Commit Logs</h4>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                              {pos.achievements.map((item) => (
                                <div class="flex items-start gap-3 p-4 border border-[#00ffd1]/10 bg-[#000000] hover:border-[#00ffd1]/40 transition-colors">
                                  <div class="mt-1 w-3 h-3 border border-[#00ffd1] flex items-center justify-center flex-shrink-0">
                                    <div class="w-1 h-1 bg-[#00ffd1]"></div>
                                  </div>
                                  <span class="text-white text-xs font-sans leading-relaxed">{item}</span>
                                </div>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>
                    </div>

                  </div>
                </div>
              ))}
            </div>

          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
