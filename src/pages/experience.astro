---
import Layout from '../layouts/Layout.astro';
import { experiences } from '../data/experience';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import { Briefcase, MapPin, Calendar, CheckCircle2 } from '@lucide/astro';

---

<Layout title="Experience | Shibili Aman">
  <Navbar />
  <main class="bg-black min-h-screen pt-12 md:pt-32 pb-32 px-4 xs:px-6 sm:px-10 md:px-24 font-mono overflow-x-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="mb-8 md:mb-24 px-4 border-l-2 border-white/10">
        <h2 class="text-[8px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] text-zinc-600 mb-2 md:mb-4 font-bold">Journey & Growth</h2>
        <h1 class="text-5xl md:text-8xl font-bold uppercase tracking-tighter leading-none">Career <br/> <span class="text-zinc-800">History</span></h1>
      </div>

      <div class="space-y-6 md:space-y-12">
        {experiences.map((exp) => (
          <div class="group relative bg-zinc-950/40 border border-white/5 p-6 md:p-10 rounded-2xl md:rounded-[3rem] hover:border-white/10 transition-all duration-500 overflow-hidden">
            <!-- Background Decoration -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 blur-[80px] rounded-full -mr-16 -mt-16 group-hover:bg-white/10 transition-colors"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-10 relative z-10">
              <div class="md:col-span-1 md:border-r border-white/5 md:pr-6 pb-4 md:pb-0">
                <span class="text-[8px] md:text-[10px] uppercase tracking-[0.3em] text-zinc-600 block mb-3 font-bold">Timeline</span>
                <div class="flex items-center gap-3 text-zinc-400">
                  <Calendar size={14} class="text-zinc-600" />
                  <span class="text-xs md:text-sm font-light italic">{exp.period}</span>
                </div>
              </div>
              
              <div class="md:col-span-3">
                <div class="flex flex-col md:flex-row justify-between items-start mb-6 md:mb-8 gap-4">
                  <div>
                    <h2 class="text-2xl md:text-4xl font-bold uppercase tracking-tighter mb-1 md:mb-2 group-hover:text-zinc-200 transition-colors leading-none">
                      {exp.role}
                    </h2>
                    <p class="text-sm md:text-lg font-light text-zinc-500 italic">@ {exp.company}</p>
                  </div>
                  <div class="flex flex-wrap gap-1.5 md:gap-2 pt-2 md:pt-0">
                    {exp.tags.map((tag) => (
                      <span class="px-2 md:px-3 py-1 bg-zinc-900/50 border border-white/5 rounded-md text-[7px] md:text-[9px] uppercase tracking-widest text-zinc-500 font-bold group-hover:border-white/10 group-hover:text-zinc-400 transition-all">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <p class="text-zinc-400 text-sm md:text-lg font-light mb-8 max-w-3xl leading-relaxed font-sans">
                  {exp.description}
                </p>

                {exp.achievements && (
                  <div class="space-y-4 pt-6 border-t border-white/5">
                    <span class="text-[8px] md:text-[10px] uppercase tracking-[0.3em] text-zinc-600 block mb-4 font-bold italic">Milestones</span>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-5">
                      {exp.achievements.map((item) => (
                        <li class="flex items-start gap-3 text-zinc-500 text-[11px] md:text-sm font-light font-sans group-hover:text-zinc-400 transition-colors">
                          <CheckCircle2 size={14} class="mt-0.5 text-zinc-800 flex-shrink-0 group-hover:text-zinc-600" />
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
