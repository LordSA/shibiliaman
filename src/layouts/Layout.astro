---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro'
import '../styles/global.css';
import CustomCursor from '../components/CustomCursor.astro';
import Canvas3D from '../components/Canvas3D.tsx';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Shibili Aman | Full-Stack Developer & CSE Student Portfolio",
	description = "Official portfolio of Shibili Aman TK, a Full-Stack Developer and B.Tech CSE student specializing in Astro, React, and building scalable web solutions."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const canonicalOrigin = Astro.url.origin;
const personStructuredData = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Shibili Aman TK',
	alternateName: 'Shibili Aman',
	url: canonicalOrigin,
	image: `${canonicalOrigin}/shibili.webp`,
	description: 'B.Tech CSE student at College of Engineering Vadakara and Full-Stack Developer building scalable solutions and developer tools.',
	jobTitle: 'B.Tech CSE Student and Full-Stack Developer',
	sameAs: [
		'https://github.com/LordSA',
		'https://www.linkedin.com/in/shibili-aman-tk',
		'https://x.com/shibiliii_aman',
		'https://tinkerhub.org/@shibiliamantk',
		'https://instagram.com/__shibiliii._',
		'https://www.wikidata.org/wiki/Q139373740',
	],
	affiliation: {
		'@type': 'CollegeOrUniversity',
		name: 'College of Engineering Vadakara',
	},
	knowsAbout: [
		'Python',
		'JavaScript',
		'TypeScript',
		'Astro',
		'UI/UX',
		'Automation',
		'Bot Development',
		'Web Performance',
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg"/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL.toString()} />
		<link rel="api-catalog" href="/.well-known/api-catalog" />
		<link rel="service-doc" href="/llms.txt" />
		<link rel="alternate" type="text/markdown" href="/llms.txt" title="Markdown for Agents" />
		<link rel="help" href="/.well-known/security.txt" />
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.toString()} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={`${canonicalOrigin}/shibili.webp`} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL.toString()} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={`${canonicalOrigin}/shibili.webp`} />
		<ClientRouter />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
		<script type="application/ld+json" set:html={JSON.stringify(personStructuredData)}></script>
		<Analytics/>
	</head>
	<body class="bg-black text-white selection:bg-white selection:text-black min-h-screen">
		<CustomCursor />
		<Canvas3D client:idle />
		<div class="fixed inset-0 pointer-events-none z-[999] opacity-[0.03]" style="background-image: url('https://grainy-gradients.vercel.app/noise.svg');"></div>
		<slot />
		<script is:inline>
			if ('modelContext' in navigator) {
				navigator.modelContext.provideContext({
					tools: [
						{
							name: "get_shibili_contact",
							description: "Get contact links and social handles for Shibili Aman",
							inputSchema: { type: "object", properties: {} },
							execute: async () => {
								return {
									content: [
										{ type: "text", text: "Portfolio: https://shibili.tech\nGitHub: https://github.com/LordSA\nLinkedIn: https://linkedin.com/in/shibili-aman-tk" }
									]
								};
							}
						}
					]
				});
			}
		</script>
		<script>
			import Lenis from 'lenis';
			import 'lenis/dist/lenis.css';

			let lenis: Lenis | null = null;

			const initLenis = () => {
				if (lenis) {
					lenis.destroy();
				}

				lenis = new Lenis({
					duration: 1.2,
					easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
					orientation: 'vertical',
					gestureOrientation: 'vertical',
					smoothWheel: true,
					touchMultiplier: 2,
					infinite: false,
					wheelMultiplier: 1,
				});

				function raf(time: number) {
					lenis?.raf(time);
					requestAnimationFrame(raf);
				}

				requestAnimationFrame(raf);
				
				lenis.start();
			};

			initLenis();

			document.addEventListener('astro:after-swap', () => {
				initLenis();
				window.scrollTo(0, 0);
			});

		</script>
	</body>
</html>

<style is:global>
	html {
		height: 100%;
		overflow-y: auto;
		scroll-behavior: auto !important;
	}

	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		cursor: none !important;
		background: black;
	}

	html.lenis, html.lenis body {
		height: auto;
	}

	.lenis.lenis-smooth {
		scroll-behavior: auto !important;
	}

	.lenis.lenis-smooth [data-lenis-prevent] {
		overscroll-behavior: contain;
	}

	.lenis.lenis-stopped {
		overflow: hidden;
	}

	.lenis.lenis-scrolling iframe {
		pointer-events: none;
	}

	@media (hover: hover) {
		a, button, [role="button"], input, textarea, select {
			cursor: none !important;
		}
	}

	@media (hover: none) and (pointer: coarse) {
		html, body, *, a, button {
			cursor: auto !important;
		}
	}
</style>
