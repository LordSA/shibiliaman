---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/time-traveler.css';
import '../styles/architect-theme.css';
import CustomCursor from '../components/CustomCursor.astro';
import Canvas3D from '../components/Canvas3D.tsx';
import TerminalCheat from '../components/cheats/TerminalCheat.astro';
import TimeTravelerCheat from '../components/cheats/TimeTravelerCheat.astro';
import ChaosCheat from '../components/cheats/ChaosCheat.astro';
import SqlInjectionCheat from '../components/cheats/SqlInjectionCheat.astro';
import ArchitectCheat from '../components/cheats/ArchitectCheat.astro';

interface Props {
	title?: string;
}

const { title = "Shibili Aman | Portfolio" } = Astro.props;
const canonicalOrigin = Astro.url.origin;
const personStructuredData = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Shibili Aman TK',
	alternateName: 'Shibili Aman',
	url: canonicalOrigin,
	image: `${canonicalOrigin}/shibili.webp`,
	description: 'B.Tech CSE student at College of Engineering Vadakara and Full-Stack Developer building scalable solutions and developer tools.',
	jobTitle: 'B.Tech CSE Student and Full-Stack Developer',
	sameAs: [
		'https://github.com/LordSA',
		'https://www.linkedin.com/in/shibili-aman-tk',
		'https://x.com/shibiliii_aman',
		'https://tinkerhub.org/@shibiliamantk',
		'https://instagram.com/__shibiliii._',
		'https://www.wikidata.org/wiki/Q139373740',
	],
	affiliation: {
		'@type': 'CollegeOrUniversity',
		name: 'College of Engineering Vadakara',
	},
	knowsAbout: [
		'Python',
		'JavaScript',
		'TypeScript',
		'Astro',
		'UI/UX',
		'Automation',
		'Bot Development',
		'Web Performance',
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
		<script type="application/ld+json" set:html={JSON.stringify(personStructuredData)}></script>
	</head>
	<body class="bg-black text-white selection:bg-white selection:text-black min-h-screen">
		<CustomCursor />
		<Canvas3D client:load />
		<div class="fixed inset-0 pointer-events-none z-[999] opacity-[0.03]" style="background-image: url('https://grainy-gradients.vercel.app/noise.svg');"></div>
		<slot />
		<div id="cheat-menu-overlay" class="cheat-menu-overlay" aria-hidden="true">
			<div class="cheat-menu-panel" role="dialog" aria-modal="true" aria-labelledby="cheat-menu-title">
				<div class="cheat-menu-head">
					<p class="cheat-menu-tag">Dev Console</p>
					<h2 id="cheat-menu-title">Cheat Menu</h2>
					<button id="cheat-menu-close" type="button" class="cheat-menu-close" aria-label="Close cheat menu">Close</button>
				</div>
				<p class="cheat-menu-note">Debug shortcuts and quick actions live here. Hooks are ready for real commands.</p>
				<div class="cheat-menu-items">
					<button id="cheat-open-terminal" type="button" class="cheat-item" data-cheat="terminal-access">
						<span class="cheat-item-title">Terminal Access</span>
						<span class="cheat-item-sub">Live temporary site edits</span>
					</button>
					<button id="cheat-open-time-traveler" type="button" class="cheat-item" data-cheat="time-traveler-mode">
						<span class="cheat-item-title">Time Traveler Mode</span>
						<span class="cheat-item-sub">Modern to 90s retro UI</span>
					</button>
					<button id="cheat-open-chaos" type="button" class="cheat-item" data-cheat="chaos-mode">
						<span class="cheat-item-title">Chaos Mode</span>
						<span class="cheat-item-sub">Physics drag playground</span>
					</button>
					<button id="cheat-open-sql-sim" type="button" class="cheat-item" data-cheat="sql-simulator-mode">
						<span class="cheat-item-title">SQL Injection Sim</span>
						<span class="cheat-item-sub">Unlock secret projects</span>
					</button>
					<button id="cheat-open-architect" type="button" class="cheat-item" data-cheat="architect-mode">
						<span class="cheat-item-title">The Architect</span>
						<span class="cheat-item-sub">Live style editor</span>
					</button>
				</div>
				<TerminalCheat />
				<TimeTravelerCheat />
				<ChaosCheat />
				<SqlInjectionCheat />
				<ArchitectCheat />
			</div>
		</div>
		<script>
			import Lenis from 'lenis';
			import 'lenis/dist/lenis.css';
			import { initTerminalCheat } from '../cheats/terminalCheat';
			import { initTimeTravelerCheat } from '../cheats/timeTravelerCheat';
			import { destroyChaosCheat, initChaosCheat } from '../cheats/chaosCheat';
			import { destroySqlInjectionCheat, initSqlInjectionCheat } from '../cheats/sqlInjectionCheat';
			import { destroyArchitectCheat, initArchitectCheat } from '../cheats/architectCheat';

			let lenis: Lenis | null = null;

			const initLenis = () => {
				if (lenis) {
					lenis.destroy();
				}

				lenis = new Lenis({
					duration: 1.2,
					easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
					orientation: 'vertical',
					gestureOrientation: 'vertical',
					smoothWheel: true,
					touchMultiplier: 2,
					infinite: false,
					wheelMultiplier: 1,
				});

				function raf(time: number) {
					lenis?.raf(time);
					requestAnimationFrame(raf);
				}

				requestAnimationFrame(raf);
				
				lenis.start();
			};

			initLenis();

			document.addEventListener('astro:after-swap', () => {
				initLenis();
				window.scrollTo(0, 0);
			});

			type CheatMenuState = {
				buffer: string[];
				lastBufferAt: number;
			};

			declare global {
				interface Window {
					__cheatMenuInitialized?: boolean;
					__cheatMenuState?: CheatMenuState;
				}
			}

			const CHEAT_SEQUENCE = ['2', '2', '5', '5'];
			const BUFFER_TIMEOUT_MS = 1800;

			const getCheatElements = () => {
				const overlay = document.getElementById('cheat-menu-overlay');
				const closeBtn = document.getElementById('cheat-menu-close');
				return { overlay, closeBtn };
			};

			const setMenuVisible = (visible: boolean) => {
				const { overlay } = getCheatElements();
				if (!overlay) return;

				overlay.classList.toggle('is-open', visible);
				overlay.setAttribute('aria-hidden', String(!visible));
			};

			const toggleMenu = () => {
				const { overlay } = getCheatElements();
				if (!overlay) return;
				setMenuVisible(!overlay.classList.contains('is-open'));
			};

			const resetBuffer = () => {
				window.__cheatMenuState = {
					buffer: [],
					lastBufferAt: 0,
				};
			};

			const hasTypedSequence = () => {
				const state = window.__cheatMenuState;
				if (!state) return false;
				if (state.buffer.length !== CHEAT_SEQUENCE.length) return false;
				return state.buffer.every((value, idx) => value === CHEAT_SEQUENCE[idx]);
			};

			const onKeydown = (event: KeyboardEvent) => {
				if (!window.__cheatMenuState) {
					resetBuffer();
				}

				const state = window.__cheatMenuState!;
				const now = Date.now();

				if (now - state.lastBufferAt > BUFFER_TIMEOUT_MS) {
					state.buffer = [];
				}

				if (event.key === '2' || event.key === '5') {
					state.buffer.push(event.key);
					if (state.buffer.length > CHEAT_SEQUENCE.length) {
						state.buffer = state.buffer.slice(-CHEAT_SEQUENCE.length);
					}
					state.lastBufferAt = now;
					return;
				}

				if (event.shiftKey && event.key.toLowerCase() === 'l' && hasTypedSequence()) {
					toggleMenu();
					resetBuffer();
					return;
				}

				if (event.key === 'Escape') {
					setMenuVisible(false);
					return;
				}

				if (!event.shiftKey) {
					state.buffer = [];
				}
			};

			const wireCheatMenuActions = () => {
				const { overlay, closeBtn } = getCheatElements();
				if (!overlay || !closeBtn) return;

				closeBtn.onclick = () => setMenuVisible(false);
				overlay.onclick = (event) => {
					if (event.target === overlay) {
						setMenuVisible(false);
					}
				};
			};

			if (!window.__cheatMenuInitialized) {
				window.__cheatMenuInitialized = true;
				resetBuffer();
				document.addEventListener('keydown', onKeydown);
			}

			wireCheatMenuActions();
			initTerminalCheat();
			initTimeTravelerCheat();
			initChaosCheat();
			initSqlInjectionCheat();
			initArchitectCheat();

			document.addEventListener('astro:after-swap', () => {
				destroyChaosCheat();
				destroySqlInjectionCheat();
				destroyArchitectCheat();
				wireCheatMenuActions();
				initTerminalCheat();
				initTimeTravelerCheat();
				initChaosCheat();
				initSqlInjectionCheat();
				initArchitectCheat();
				setMenuVisible(false);
				resetBuffer();
			});
		</script>
	</body>
</html>

<style is:global>
	html {
		height: 100%;
		overflow-y: auto;
		scroll-behavior: auto !important;
	}

	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		cursor: none !important;
		background: black;
	}

	html.lenis, html.lenis body {
		height: auto;
	}

	.lenis.lenis-smooth {
		scroll-behavior: auto !important;
	}

	.lenis.lenis-smooth [data-lenis-prevent] {
		overscroll-behavior: contain;
	}

	.lenis.lenis-stopped {
		overflow: hidden;
	}

	.lenis.lenis-scrolling iframe {
		pointer-events: none;
	}

	@media (hover: hover) {
		a, button, [role="button"], input, textarea, select {
			cursor: none !important;
		}
	}

	@media (hover: none) and (pointer: coarse) {
		html, body, *, a, button {
			cursor: auto !important;
		}
	}

	.cheat-menu-overlay {
		position: fixed;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		background:
			radial-gradient(circle at 20% 20%, rgba(35, 190, 255, 0.14), transparent 42%),
			radial-gradient(circle at 80% 80%, rgba(255, 116, 116, 0.1), transparent 38%),
			rgba(0, 0, 0, 0.78);
		backdrop-filter: blur(12px);
		opacity: 0;
		pointer-events: none;
		transform: translateY(0.75rem) scale(0.985);
		transition: opacity 0.24s ease, transform 0.24s ease;
		z-index: 2000;
	}

	.cheat-menu-overlay.is-open {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0) scale(1);
	}

	.cheat-menu-panel {
		position: relative;
		overflow: hidden;
		width: min(92vw, 560px);
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 20px;
		padding: 1.1rem;
		background: linear-gradient(160deg, rgba(10, 12, 16, 0.96), rgba(20, 20, 24, 0.94));
		box-shadow: 0 26px 50px rgba(0, 0, 0, 0.48);
	}

	.cheat-menu-panel::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			linear-gradient(120deg, rgba(78, 214, 255, 0.2) 0%, transparent 45%),
			repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.045) 0, rgba(255, 255, 255, 0.045) 1px, transparent 1px, transparent 22px);
		opacity: 0.35;
	}

	.cheat-menu-head {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.6rem;
		align-items: center;
		margin-bottom: 0.95rem;
		padding-bottom: 0.65rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
	}

	.cheat-menu-tag {
		grid-column: 1 / -1;
		font-size: 0.66rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(160, 220, 255, 0.78);
		margin: 0;
		font-family: 'JetBrains Mono', monospace;
	}

	.cheat-menu-head h2 {
		margin: 0;
		font-size: clamp(1.2rem, 2.4vw, 1.45rem);
		letter-spacing: 0.07em;
		text-transform: uppercase;
		line-height: 1.1;
	}

	.cheat-menu-close {
		appearance: none;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.04);
		color: #fff;
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		padding: 0.4rem 0.72rem;
		border-radius: 999px;
		transition: border-color 0.2s ease, background 0.2s ease;
	}

	.cheat-menu-close:hover,
	.cheat-menu-close:focus-visible {
		border-color: rgba(161, 228, 255, 0.7);
		background: rgba(111, 201, 255, 0.14);
		outline: none;
	}

	.cheat-menu-note {
		position: relative;
		z-index: 1;
		margin: 0.35rem 0 0.95rem;
		font-size: 0.88rem;
		line-height: 1.45;
		color: rgba(245, 247, 255, 0.78);
	}

	.cheat-menu-items {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.cheat-item {
		appearance: none;
		text-align: left;
		display: grid;
		gap: 0.18rem;
		border: 1px solid rgba(255, 255, 255, 0.16);
		background: linear-gradient(165deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
		color: #fff;
		padding: 0.72rem 0.65rem;
		border-radius: 12px;
		transition: transform 0.18s ease, border-color 0.2s ease, background 0.2s ease;
	}

	.cheat-item-title {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 700;
	}

	.cheat-item-sub {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.62rem;
		letter-spacing: 0.02em;
		color: rgba(255, 255, 255, 0.56);
	}

	.cheat-item:hover,
	.cheat-item:focus-visible {
		transform: translateY(-2px);
		border-color: rgba(122, 219, 255, 0.7);
		background: linear-gradient(165deg, rgba(104, 210, 255, 0.2), rgba(255, 255, 255, 0.04));
		outline: none;
	}

	@media (max-width: 640px) {
		.cheat-menu-panel {
			padding: 1rem 0.9rem;
		}

		.cheat-menu-items {
			grid-template-columns: 1fr;
		}
	}
</style>
